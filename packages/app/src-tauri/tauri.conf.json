{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "VoxFusion",
	"version": "0.1.0",
	"identifier": "io.voxfusion.app",
	"bundle": {
		"macOS": {
			"entitlements": "entitlements.plist"
		}
	},
	"build": {
		"beforeDevCommand": "vite",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"withGlobalTauri": false,
		"windows": [
			{
				"label": "main",
				"title": "VoxFusion",
				"width": 1360,
				"height": 850,
				"resizable": true,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true,
				"fullscreen": false,
				"center": true
			},
			{
				"label": "voice-control",
				"title": "Voice Control",
				"url": "/voice-control",
				"width": 280,
				"height": 64,
				"resizable": false,
				"decorations": true,
				"transparent": true,
				"alwaysOnTop": true,
				"skipTaskbar": true,
				"visible": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {
		"opener": {},
		"deep-link": {
			"mobile": [],
			"desktop": {
				"schemes": ["voxfusion"]
			}
		}
	}
}
