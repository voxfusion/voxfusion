{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "VoxFusion",
	"version": "0.3.0",
	"identifier": "io.voxfusion.app",
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": ["dmg", "app"],
		"icon": ["icons/icon.icns", "icons/icon.png"],
		"macOS": {
			"entitlements": "entitlements.plist",
			"minimumSystemVersion": "10.15",
			"hardenedRuntime": true,
			"signingIdentity": "Developer ID Application: Egor tokarev (P2M3JQ4DR5)"
		}
	},
	"build": {
		"beforeDevCommand": "vite",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"withGlobalTauri": false,
		"windows": [
			{
				"label": "main",
				"title": "VoxFusion",
				"width": 1360,
				"height": 850,
				"minWidth": 1024,
				"minHeight": 720,
				"resizable": true,
				"decorations": true,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true,
				"fullscreen": false,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {
		"opener": {},
		"updater": {
			"endpoints": [
				"https://github.com/voxfusion/voxfusion/releases/latest/download/latest.json"
			],
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzOTdCMUNCQjZCMDM3N0EKUldSNk43QzJ5N0dYbzhVajRWT1hkdk4rMTlqU3hJWHRhbG1xQ2xncUE3ek9iOWZTT3h6cmJIalMK"
		}
	}
}
