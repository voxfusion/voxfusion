{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "VoxFusion",
	"version": "0.1.0",
	"identifier": "io.voxfusion.app",
	"build": {
		"beforeDevCommand": "vite",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"withGlobalTauri": false,
		"windows": [
			{
				"width": 1360,
				"height": 850,
				"resizable": true,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true,
				"fullscreen": false,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {
		"opener": {}
	}
}
