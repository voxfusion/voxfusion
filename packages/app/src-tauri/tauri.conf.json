{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "VoxFusion",
	"version": "0.1.0",
	"identifier": "com.voxfusion.app",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": false,
		"windows": [
			{
				"title": "VoxFusion",
				"width": 1200,
				"height": 800,
				"resizable": true,
				"fullscreen": false,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {
		"opener": {
			"openUrl": {
				"enabled": true
			}
		}
	}
}
