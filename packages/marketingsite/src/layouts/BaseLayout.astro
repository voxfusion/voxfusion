---
/**
 * Shared page shell for the whole site: head (Seo, fonts, favicons),
 * fixed nav with logo, grid overlay, footer, Umami analytics, and the
 * global base styles every page relies on.
 *
 * Nav variants:
 *   - showNavLinks renders the Features / GitHub link group.
 *   - ctaHref + ctaLabel render the bordered CTA on the right.
 *   - <slot name="nav-extra" /> renders inside <nav> after .nav-inner
 *     (used by the download page's mobile menu).
 *   - showFooter=false lets a page render its own footer (404).
 */
import Footer from "../components/Footer.astro";
import Seo from "../components/Seo.astro";
import Umami from "../components/Umami.astro";
import { defaultLang, getLocalizedPath, type languages, useTranslations } from "../i18n/utils";

interface Props {
	title: string;
	description: string;
	lang?: keyof typeof languages;
	noindex?: boolean;
	schema?: Record<string, unknown>;
	showNavLinks?: boolean;
	ctaHref?: string;
	ctaLabel?: string;
	bodyClass?: string;
	showFooter?: boolean;
}

const {
	title,
	description,
	lang = defaultLang,
	noindex = false,
	schema,
	showNavLinks = false,
	ctaHref,
	ctaLabel,
	bodyClass,
	showFooter = true,
} = Astro.props;
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
<head>
	<meta charset="UTF-8" />
	<Seo title={title} description={description} lang={lang} noindex={noindex} schema={schema} />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
	<meta name="mailru-domain" content="a5ieqZ6Dkv267Psx" />
	<title>{title}</title>
</head>
<body class={bodyClass}>
	<div class="grid-overlay"></div>

	<nav class="nav">
		<div class="nav-inner">
			<a href={getLocalizedPath("/", lang)} class="logo">
				<span class="logo-bracket">[</span>VOX<span class="logo-accent">FUSION</span><span class="logo-bracket">]</span>
			</a>
			{showNavLinks && (
				<div class="nav-links">
					<a href={getLocalizedPath("/", lang) + "#features"} class="nav-link"><span class="link-index">01</span>{t("nav.features")}</a>
					<a href="https://github.com/voxfusion/voxfusion" target="_blank" rel="noopener noreferrer" class="nav-link"><span class="link-index">02</span>{t("nav.github")}</a>
				</div>
			)}
			{ctaHref && ctaLabel && <a href={ctaHref} class="nav-cta">{ctaLabel}</a>}
		</div>
		<slot name="nav-extra" />
	</nav>

	<slot />

	{showFooter && <Footer lang={lang} />}
	<Umami />
</body>
</html>

<style is:global>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	a {
		text-decoration: none;
		color: inherit;
	}

	html {
		font-family: "JetBrains Mono", "Space Mono", monospace;
		background: #0a0a0a;
		color: #e0e0e0;
		scroll-behavior: smooth;
		font-size: 15px;
	}

	body {
		min-height: 100vh;
		position: relative;
	}

	.grid-overlay {
		position: fixed;
		inset: 0;
		background-image:
			linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
		background-size: 40px 40px;
		pointer-events: none;
		z-index: 0;
	}

	/* Navigation */
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		border-bottom: 1px solid #222;
		background: rgba(10, 10, 10, 0.95);
		backdrop-filter: blur(10px);
	}

	.nav-inner {
		max-width: 1400px;
		margin: 0 auto;
		padding: 16px 32px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		font-size: 18px;
		font-weight: 700;
		letter-spacing: 0.1em;
		color: #e0e0e0;
	}

	.logo-bracket {
		color: #ff3e00;
	}

	.logo-accent {
		color: #666;
	}

	.nav-links {
		display: flex;
		gap: 32px;
	}

	.nav-link {
		font-size: 13px;
		color: #888;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: color 0.2s;
	}

	.nav-link:hover {
		color: #fff;
	}

	.link-index {
		color: #ff3e00;
		margin-right: 8px;
	}

	.nav-cta {
		padding: 10px 20px;
		border: 1px solid #ff3e00;
		color: #ff3e00;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: all 0.2s;
	}

	.nav-cta:hover {
		background: #ff3e00;
		color: #000;
	}

	@media (max-width: 768px) {
		.nav-links {
			display: none;
		}
	}
</style>
