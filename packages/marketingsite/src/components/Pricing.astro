---
import { useTranslations, defaultLang, languages } from "../i18n/utils";

interface Props {
	lang?: keyof typeof languages;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const checkIconAccent = `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="var(--color-accent)" fill-opacity="0.15"/><path d="M6 10L9 13L14 7" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
const checkIconPrimary = `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="var(--color-primary)" fill-opacity="0.15"/><path d="M6 10L9 13L14 7" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
---

<section id="pricing" class="pricing">
	<div class="container">
		<div class="section-header">
			<span class="section-tag">{t("pricing.tag")}</span>
			<h2 class="section-title">{t("pricing.title")}</h2>
			<p class="section-description">{t("pricing.description")}</p>
		</div>

		<div class="pricing-grid">
			<div class="pricing-card">
				<div class="pricing-header">
					<span class="plan-name">{t("pricing.free.name")}</span>
					<div class="plan-price">
						<span class="price-amount">{t("pricing.free.price")}</span>
						<span class="price-period">{t("pricing.free.period")}</span>
					</div>
					<p class="plan-description">{t("pricing.free.description")}</p>
				</div>

				<ul class="plan-features">
					<li>
						<Fragment set:html={checkIconAccent} />
						<span>{t("pricing.free.feature1")}</span>
					</li>
					<li>
						<Fragment set:html={checkIconAccent} />
						<span>{t("pricing.free.feature2")}</span>
					</li>
					<li>
						<Fragment set:html={checkIconAccent} />
						<span>{t("pricing.free.feature3")}</span>
					</li>
					<li>
						<Fragment set:html={checkIconAccent} />
						<span>{t("pricing.free.feature4")}</span>
					</li>
					<li>
						<Fragment set:html={checkIconAccent} />
						<span>{t("pricing.free.feature5")}</span>
					</li>
				</ul>

				<a href="#download" class="pricing-cta">
					{t("pricing.free.cta")}
				</a>
			</div>

			<div class="pricing-card featured">
				<div class="featured-badge">{t("pricing.pro.badge")}</div>
				<div class="pricing-header">
					<span class="plan-name">{t("pricing.pro.name")}</span>
					<div class="plan-price">
						<span class="price-amount">{t("pricing.pro.price")}</span>
						<span class="price-period">{t("pricing.pro.period")}</span>
					</div>
					<p class="plan-description">{t("pricing.pro.description")}</p>
				</div>

				<ul class="plan-features">
					<li>
						<Fragment set:html={checkIconPrimary} />
						<span><strong>{t("pricing.pro.feature1")}</strong>{t("pricing.pro.feature1.suffix")}</span>
					</li>
					<li>
						<Fragment set:html={checkIconPrimary} />
						<span>{t("pricing.pro.feature2")}</span>
					</li>
					<li>
						<Fragment set:html={checkIconPrimary} />
						<span>{t("pricing.pro.feature3")}</span>
					</li>
					<li>
						<Fragment set:html={checkIconPrimary} />
						<span>{t("pricing.pro.feature4")}</span>
					</li>
				</ul>

				<a href="#download" class="pricing-cta featured-cta">
					{t("pricing.pro.cta")}
				</a>
			</div>
		</div>

		<div class="pricing-faq">
			<p class="faq-note">
				<svg width="20" height="20" viewBox="0 0 20 20" fill="none">
					<circle cx="10" cy="10" r="9" stroke="var(--color-text-muted)" stroke-width="1.5"/>
					<path d="M10 14V10M10 6H10.01" stroke="var(--color-text-muted)" stroke-width="1.5" stroke-linecap="round"/>
				</svg>
				<span>{t("pricing.faq")} <a href="mailto:hello@voxfusion.com">hello@voxfusion.com</a> {t("pricing.faq.suffix")}</span>
			</p>
		</div>
	</div>
</section>

<style>
	.pricing {
		padding: 120px 0;
		background: var(--color-bg);
	}

	.section-header {
		text-align: center;
		margin-bottom: 64px;
	}

	.section-tag {
		display: inline-block;
		padding: 6px 14px;
		background: rgba(255, 107, 74, 0.1);
		border: 1px solid rgba(255, 107, 74, 0.2);
		border-radius: 100px;
		font-size: 13px;
		font-weight: 600;
		color: var(--color-primary);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 20px;
	}

	.section-title {
		font-size: clamp(28px, 4vw, 44px);
		font-weight: 800;
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin-bottom: 16px;
	}

	.section-description {
		font-size: 18px;
		color: var(--color-text-secondary);
	}

	.pricing-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 32px;
		max-width: 900px;
		margin: 0 auto;
	}

	.pricing-card {
		position: relative;
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 24px;
		padding: 40px;
		display: flex;
		flex-direction: column;
	}

	.pricing-card.featured {
		border-color: var(--color-primary);
		background: linear-gradient(135deg, rgba(255, 107, 74, 0.05) 0%, var(--color-bg-card) 100%);
	}

	.featured-badge {
		position: absolute;
		top: -12px;
		left: 50%;
		transform: translateX(-50%);
		padding: 6px 16px;
		background: var(--color-primary);
		color: white;
		font-size: 12px;
		font-weight: 700;
		border-radius: 100px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.pricing-header {
		margin-bottom: 32px;
	}

	.plan-name {
		font-size: 16px;
		font-weight: 600;
		color: var(--color-text-secondary);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 12px;
		display: block;
	}

	.plan-price {
		display: flex;
		align-items: baseline;
		gap: 8px;
		margin-bottom: 12px;
	}

	.price-amount {
		font-size: 56px;
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1;
	}

	.price-period {
		font-size: 16px;
		color: var(--color-text-muted);
	}

	.plan-description {
		font-size: 15px;
		color: var(--color-text-secondary);
	}

	.plan-features {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 16px;
		margin-bottom: 32px;
		flex: 1;
	}

	.plan-features li {
		display: flex;
		align-items: flex-start;
		gap: 12px;
		font-size: 15px;
		color: var(--color-text-secondary);
		line-height: 1.4;
	}

	.plan-features li svg {
		flex-shrink: 0;
		margin-top: 2px;
	}

	.plan-features li strong {
		color: var(--color-text);
		font-weight: 600;
	}

	.pricing-cta {
		display: block;
		width: 100%;
		padding: 16px 24px;
		background: var(--color-bg-secondary);
		border: 1px solid var(--color-border);
		border-radius: 12px;
		font-size: 16px;
		font-weight: 600;
		color: var(--color-text);
		text-align: center;
		transition: all 0.2s ease;
	}

	.pricing-cta:hover {
		background: var(--color-bg);
		border-color: var(--color-border-hover);
	}

	.pricing-cta.featured-cta {
		background: var(--color-primary);
		border-color: var(--color-primary);
		color: white;
	}

	.pricing-cta.featured-cta:hover {
		background: var(--color-primary-dark);
		border-color: var(--color-primary-dark);
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(255, 107, 74, 0.3);
	}

	.pricing-faq {
		margin-top: 48px;
		text-align: center;
	}

	.faq-note {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		font-size: 15px;
		color: var(--color-text-muted);
	}

	.faq-note a {
		color: var(--color-primary);
		font-weight: 500;
	}

	.faq-note a:hover {
		text-decoration: underline;
	}

	@media (max-width: 768px) {
		.pricing {
			padding: 80px 0;
		}

		.pricing-grid {
			grid-template-columns: 1fr;
			gap: 24px;
		}

		.pricing-card {
			padding: 32px;
		}

		.price-amount {
			font-size: 48px;
		}

		.section-description {
			font-size: 16px;
		}

		.faq-note {
			flex-direction: column;
			gap: 8px;
		}
	}
</style>
