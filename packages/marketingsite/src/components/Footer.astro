---
import { useTranslations, defaultLang, languages } from "../i18n/utils";

interface Props {
	lang?: keyof typeof languages;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="footer">
	<div class="footer-grid">
		<div class="footer-brand">
			<span class="footer-logo">[VOX<span>FUSION</span>]</span>
			<p>{t("footer.tagline")}</p>
		</div>
		<div class="footer-links">
			<div class="link-group">
				<h4>{t("footer.product")}</h4>
				<a href="/#features">{t("nav.features")}</a>
				<a href="/download">{t("nav.download")}</a>
				<a href="#">{t("footer.changelog")}</a>
			</div>
			<div class="link-group">
				<h4>{t("footer.legal")}</h4>
				<a href="/privacy">{t("footer.privacy")}</a>
				<a href="/terms">{t("footer.terms")}</a>
				<a href="/security">{t("footer.security")}</a>
			</div>
		</div>
	</div>
	<div class="footer-bottom">
		<span>&copy; 2025 {t("footer.copyright")}</span>
		<span class="footer-status"><span class="status-dot"></span> {t("footer.status")}</span>
	</div>
</footer>

<style>
	.footer {
		border-top: 1px solid #222;
		padding: 60px 32px 40px;
		max-width: 1400px;
		margin: 0 auto;
		font-family: "JetBrains Mono", "Space Mono", monospace;
	}

	.footer a {
		text-decoration: none;
		color: inherit;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: 80px;
		margin-bottom: 48px;
	}

	.footer-logo {
		font-size: 18px;
		font-weight: 700;
		letter-spacing: 0.1em;
	}

	.footer-logo span {
		color: #666;
	}

	.footer-brand p {
		font-size: 13px;
		color: #666;
		margin-top: 16px;
		line-height: 1.6;
	}

	.social-links {
		display: flex;
		gap: 16px;
		margin-top: 24px;
	}

	.social-links a {
		width: 36px;
		height: 36px;
		border: 1px solid #333;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 11px;
		color: #666;
		transition: all 0.2s;
	}

	.social-links a:hover {
		border-color: #ff3e00;
		color: #ff3e00;
	}

	.footer-links {
		display: flex;
		justify-content: flex-end;
		gap: 40px;
	}

	.link-group h4 {
		font-size: 11px;
		color: #666;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 20px;
	}

	.link-group a {
		display: block;
		font-size: 13px;
		color: #888;
		margin-bottom: 12px;
		transition: color 0.2s;
	}

	.link-group a:hover {
		color: #ff3e00;
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		padding-top: 24px;
		border-top: 1px solid #222;
		font-size: 12px;
		color: #666;
	}

	.footer-status {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.status-dot {
		width: 8px;
		height: 8px;
		background: #00ff88;
		border-radius: 50%;
	}

	@media (max-width: 768px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: 48px;
		}

		.footer-links {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
