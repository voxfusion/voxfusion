---
import { useTranslations, defaultLang, languages } from "../i18n/utils";

interface Props {
	lang?: keyof typeof languages;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const reviews = [
	{
		name: "Sarah Chen",
		handle: "@sarahchen_dev",
		avatar: "SC",
		content: "I've tried every voice note app out there. VoxFusion is the first one that actually makes my recordings useful. The search feature is magic.",
		date: "Dec 15, 2024",
		likes: 234,
		verified: true
	},
	{
		name: "Marcus Rodriguez",
		handle: "@marcusrod",
		avatar: "MR",
		content: "As a product manager, I record all my user interviews with VoxFusion. Being able to search through hours of conversations has changed how I do research.",
		date: "Dec 12, 2024",
		likes: 189,
		verified: false
	},
	{
		name: "Emma Watson",
		handle: "@emmawrites",
		avatar: "EW",
		content: "Finally an app that respects privacy. All my recordings stay local until I choose to sync. This is how software should be built.",
		date: "Dec 10, 2024",
		likes: 456,
		verified: true
	},
	{
		name: "David Park",
		handle: "@davidpark_io",
		avatar: "DP",
		content: "The transcription accuracy is insane. I recorded a meeting with 6 people and it identified each speaker correctly. How is this a $8/month tool?",
		date: "Dec 8, 2024",
		likes: 312,
		verified: false
	},
	{
		name: "Lisa Thompson",
		handle: "@lisathompson",
		avatar: "LT",
		content: "VoxFusion + meetings = never forgetting what was decided ever again. My team thinks I have superhuman memory now.",
		date: "Dec 5, 2024",
		likes: 278,
		verified: true
	},
	{
		name: "Alex Kumar",
		handle: "@alexk_design",
		avatar: "AK",
		content: "I use VoxFusion for brainstorming sessions with my design team. We just talk, and later I can search for any idea we discussed. Game changer.",
		date: "Dec 3, 2024",
		likes: 198,
		verified: false
	}
];
---

<section id="reviews" class="reviews">
	<div class="container">
		<div class="section-header">
			<span class="section-tag">{t("reviews.tag")}</span>
			<h2 class="section-title">{t("reviews.title")}</h2>
			<p class="section-description">{t("reviews.description")}</p>
		</div>

		<div class="reviews-grid">
			{reviews.map((review) => (
				<div class="tweet-card">
					<div class="tweet-header">
						<div class="tweet-avatar" style={`background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));`}>
							{review.avatar}
						</div>
						<div class="tweet-author">
							<div class="tweet-name">
								{review.name}
								{review.verified && (
									<svg class="verified-badge" width="16" height="16" viewBox="0 0 16 16" fill="none">
										<circle cx="8" cy="8" r="8" fill="#1DA1F2"/>
										<path d="M6 8L7.5 9.5L10.5 6.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
									</svg>
								)}
							</div>
							<span class="tweet-handle">{review.handle}</span>
						</div>
						<svg class="tweet-logo" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
							<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
						</svg>
					</div>
					<p class="tweet-content">{review.content}</p>
					<div class="tweet-footer">
						<span class="tweet-date">{review.date}</span>
						<div class="tweet-engagement">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
							</svg>
							<span>{review.likes}</span>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.reviews {
		padding: 120px 0;
		background: var(--color-bg-secondary);
	}

	.section-header {
		text-align: center;
		margin-bottom: 64px;
	}

	.section-tag {
		display: inline-block;
		padding: 6px 14px;
		background: rgba(255, 107, 74, 0.1);
		border: 1px solid rgba(255, 107, 74, 0.2);
		border-radius: 100px;
		font-size: 13px;
		font-weight: 600;
		color: var(--color-primary);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 20px;
	}

	.section-title {
		font-size: clamp(28px, 4vw, 44px);
		font-weight: 800;
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin-bottom: 16px;
	}

	.section-description {
		font-size: 18px;
		color: var(--color-text-secondary);
		max-width: 500px;
		margin: 0 auto;
	}

	.reviews-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}

	.tweet-card {
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 16px;
		padding: 24px;
		transition: all 0.3s ease;
	}

	.tweet-card:hover {
		border-color: var(--color-border-hover);
		transform: translateY(-4px);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
	}

	.tweet-header {
		display: flex;
		align-items: flex-start;
		gap: 12px;
		margin-bottom: 16px;
	}

	.tweet-avatar {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 14px;
		font-weight: 700;
		color: white;
		flex-shrink: 0;
	}

	.tweet-author {
		flex: 1;
		min-width: 0;
	}

	.tweet-name {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 15px;
		font-weight: 700;
	}

	.verified-badge {
		flex-shrink: 0;
	}

	.tweet-handle {
		font-size: 14px;
		color: var(--color-text-muted);
	}

	.tweet-logo {
		color: var(--color-text-muted);
		flex-shrink: 0;
	}

	.tweet-content {
		font-size: 15px;
		line-height: 1.6;
		color: var(--color-text);
		margin-bottom: 16px;
	}

	.tweet-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-top: 16px;
		border-top: 1px solid var(--color-border);
	}

	.tweet-date {
		font-size: 13px;
		color: var(--color-text-muted);
	}

	.tweet-engagement {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 13px;
		color: var(--color-text-muted);
	}

	.tweet-engagement svg {
		width: 14px;
		height: 14px;
	}

	@media (max-width: 1024px) {
		.reviews-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.reviews {
			padding: 80px 0;
		}

		.reviews-grid {
			grid-template-columns: 1fr;
		}

		.section-description {
			font-size: 16px;
		}
	}
</style>
