---
import { languages, getAlternateLocales, defaultLang } from "../i18n/utils";

interface Props {
	currentLang: keyof typeof languages;
}

const { currentLang } = Astro.props;
const currentPath = Astro.url.pathname;
const locales = getAlternateLocales(currentLang, currentPath);
---

<div class="language-switcher">
	<button class="language-btn" aria-label="Change language" aria-expanded="false">
		<svg class="globe-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="12" cy="12" r="10"/>
			<path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
			<path d="M2 12h20"/>
		</svg>
		<span class="current-lang">{languages[currentLang]}</span>
		<svg class="chevron-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="m6 9 6 6 6-6"/>
		</svg>
	</button>
	<div class="language-dropdown">
		{locales.map((locale) => (
			<a
				href={locale.path}
				class:list={["language-option", { active: locale.isCurrent }]}
				hreflang={locale.lang}
			>
				{locale.label}
			</a>
		))}
	</div>
</div>

<script>
	document.querySelectorAll('.language-switcher').forEach((switcher) => {
		const btn = switcher.querySelector('.language-btn');
		const dropdown = switcher.querySelector('.language-dropdown');

		btn?.addEventListener('click', () => {
			const isExpanded = btn.getAttribute('aria-expanded') === 'true';
			btn.setAttribute('aria-expanded', (!isExpanded).toString());
			dropdown?.classList.toggle('open');
		});
	});

	// Close all dropdowns when clicking outside
	document.addEventListener('click', (e) => {
		document.querySelectorAll('.language-switcher').forEach((switcher) => {
			if (!switcher.contains(e.target as Node)) {
				switcher.querySelector('.language-btn')?.setAttribute('aria-expanded', 'false');
				switcher.querySelector('.language-dropdown')?.classList.remove('open');
			}
		});
	});
</script>

<style>
	.language-switcher {
		position: relative;
	}

	.language-btn {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 8px 12px;
		background: transparent;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		color: var(--color-text-secondary);
		font-size: 14px;
		font-weight: 500;
		cursor: pointer;
		transition: all 0.2s ease;
	}

	.language-btn:hover {
		color: var(--color-text);
		border-color: var(--color-border-hover);
		background: var(--color-bg-card);
	}

	.globe-icon {
		flex-shrink: 0;
	}

	.current-lang {
		min-width: 60px;
	}

	.chevron-icon {
		flex-shrink: 0;
		transition: transform 0.2s ease;
	}

	.language-btn[aria-expanded="true"] .chevron-icon {
		transform: rotate(180deg);
	}

	.language-dropdown {
		position: absolute;
		top: calc(100% + 8px);
		right: 0;
		min-width: 140px;
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 10px;
		padding: 6px;
		opacity: 0;
		visibility: hidden;
		transform: translateY(-8px);
		transition: all 0.2s ease;
		z-index: 100;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
	}

	.language-dropdown.open {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}

	.language-option {
		display: block;
		padding: 10px 14px;
		font-size: 14px;
		font-weight: 500;
		color: var(--color-text-secondary);
		border-radius: 6px;
		transition: all 0.15s ease;
	}

	.language-option:hover {
		background: var(--color-bg-secondary);
		color: var(--color-text);
	}

	.language-option.active {
		background: rgba(255, 107, 74, 0.1);
		color: var(--color-primary);
	}
</style>
