---
/**
 * Yandex.Metrika counter + custom event tracking.
 *
 * Usage:
 *   - Place <YandexMetrika /> right before </body>.
 *   - Add data-ym-goal="goal_name" to any clickable element to fire reachGoal on click.
 *   - Add data-ym-view="goal_name" to any section to fire reachGoal when it scrolls into view.
 *   - Optionally pass data-ym-params='{"key":"value"}' for extra goal params.
 */
const COUNTER_ID = 106700472;
---

<!-- Yandex.Metrika counter -->
<script is:inline define:vars={{ COUNTER_ID }}>
  (function(m,e,t,r,i,k,a){
    m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
    m[i].l=1*new Date();
    for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
    k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
  })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js?id=' + COUNTER_ID, 'ym');

  ym(COUNTER_ID, 'init', {
    clickmap: true,
    trackLinks: true,
    accurateTrackBounce: true,
    ecommerce: 'dataLayer',
    referrer: document.referrer,
    url: location.href
  });

  // --- Custom event helpers ---

  // Click goals: any element with data-ym-goal fires reachGoal on click
  document.addEventListener('click', function(e) {
    var el = e.target.closest('[data-ym-goal]');
    if (!el) return;
    var goal = el.getAttribute('data-ym-goal');
    var raw = el.getAttribute('data-ym-params');
    var params = raw ? JSON.parse(raw) : undefined;
    ym(COUNTER_ID, 'reachGoal', goal, params);
  });

  // View goals: fire reachGoal once when a [data-ym-view] section enters the viewport
  if ('IntersectionObserver' in window) {
    var viewed = {};
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var goal = entry.target.getAttribute('data-ym-view');
        if (viewed[goal]) return;
        viewed[goal] = true;
        var raw = entry.target.getAttribute('data-ym-params');
        var params = raw ? JSON.parse(raw) : undefined;
        ym(COUNTER_ID, 'reachGoal', goal, params);
      });
    }, { threshold: 0.3 });

    document.querySelectorAll('[data-ym-view]').forEach(function(el) {
      observer.observe(el);
    });
  }
</script>
<noscript><div><img src={"https://mc.yandex.ru/watch/" + COUNTER_ID} style="position:absolute; left:-9999px;" alt="" /></div></noscript>
<!-- /Yandex.Metrika counter -->
