---
import { useTranslations, defaultLang, languages } from "../i18n/utils";

interface Props {
	lang?: keyof typeof languages;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const featureIcons = [
	// Global Hotkey - keyboard icon
	`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01"/><path d="M10 8h.01"/><path d="M14 8h.01"/><path d="M18 8h.01"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/><path d="M7 16h10"/></svg>`,
	// Instant Transcription - zap/lightning icon
	`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
	// Custom Dictionary - book icon
	`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>`,
	// Transcription History - clock/history icon
	`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
	// English & Russian - globe icon
	`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
	// Simple Setup - play/start icon
	`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>`
];

const featureKeys = [
	{ title: "features.globalHotkey.title", description: "features.globalHotkey.description" },
	{ title: "features.instantTranscription.title", description: "features.instantTranscription.description" },
	{ title: "features.customDictionary.title", description: "features.customDictionary.description" },
	{ title: "features.history.title", description: "features.history.description" },
	{ title: "features.languages.title", description: "features.languages.description" },
	{ title: "features.simpleSetup.title", description: "features.simpleSetup.description" }
] as const;
---

<section id="features" class="features">
	<div class="container">
		<div class="section-header">
			<span class="section-tag">{t("features.tag")}</span>
			<h2 class="section-title">{t("features.title")}</h2>
			<p class="section-description">{t("features.description")}</p>
		</div>

		<div class="features-grid">
			{featureKeys.map((feature, index) => (
				<div class="feature-card">
					<div class="feature-icon" set:html={featureIcons[index]}></div>
					<h3 class="feature-title">{t(feature.title)}</h3>
					<p class="feature-description">{t(feature.description)}</p>
				</div>
			))}
		</div>

		<div class="features-highlight">
			<div class="highlight-content">
				<span class="highlight-tag">{t("features.highlight.tag")}</span>
				<h3 class="highlight-title">{t("features.highlight.title")}</h3>
				<p class="highlight-description">{t("features.highlight.description")}</p>
				<ul class="highlight-list">
					<li>
						<svg width="20" height="20" viewBox="0 0 20 20" fill="none">
							<circle cx="10" cy="10" r="10" fill="var(--color-primary)" fill-opacity="0.15"/>
							<path d="M6 10L9 13L14 7" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
						<span>{t("features.highlight.list1")}</span>
					</li>
					<li>
						<svg width="20" height="20" viewBox="0 0 20 20" fill="none">
							<circle cx="10" cy="10" r="10" fill="var(--color-primary)" fill-opacity="0.15"/>
							<path d="M6 10L9 13L14 7" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
						<span>{t("features.highlight.list2")}</span>
					</li>
					<li>
						<svg width="20" height="20" viewBox="0 0 20 20" fill="none">
							<circle cx="10" cy="10" r="10" fill="var(--color-primary)" fill-opacity="0.15"/>
							<path d="M6 10L9 13L14 7" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
						<span>{t("features.highlight.list3")}</span>
					</li>
				</ul>
			</div>
			<div class="highlight-visual">
				<div class="mock-desktop">
					<div class="mock-window">
						<div class="mock-header">
							<div class="mock-dots">
								<span></span>
								<span></span>
								<span></span>
							</div>
							<span class="mock-title">Messages</span>
						</div>
						<div class="mock-content">
							<div class="mock-input-area">
								<span class="mock-typed-text">Hey team, let's schedule a meeting for tomorrow at 2pm to discuss the project timeline.</span>
								<span class="mock-cursor"></span>
							</div>
						</div>
					</div>
					<div class="voice-control-bubble">
						<div class="bubble-waveform">
							<span class="wave-bar"></span>
							<span class="wave-bar"></span>
							<span class="wave-bar"></span>
							<span class="wave-bar"></span>
							<span class="wave-bar"></span>
						</div>
						<span class="bubble-text">Listening...</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.features {
		padding: 120px 0;
		background: var(--color-bg-secondary);
	}

	.section-header {
		text-align: center;
		margin-bottom: 64px;
	}

	.section-tag {
		display: inline-block;
		padding: 6px 14px;
		background: rgba(255, 107, 74, 0.1);
		border: 1px solid rgba(255, 107, 74, 0.2);
		border-radius: 100px;
		font-size: 13px;
		font-weight: 600;
		color: var(--color-primary);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 20px;
	}

	.section-title {
		font-size: clamp(28px, 4vw, 44px);
		font-weight: 800;
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin-bottom: 16px;
		max-width: 700px;
		margin-left: auto;
		margin-right: auto;
	}

	.section-description {
		font-size: 18px;
		color: var(--color-text-secondary);
		max-width: 500px;
		margin: 0 auto;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
		margin-bottom: 80px;
	}

	.feature-card {
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 16px;
		padding: 32px;
		transition: all 0.3s ease;
	}

	.feature-card:hover {
		border-color: var(--color-border-hover);
		transform: translateY(-4px);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
	}

	.feature-icon {
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(255, 107, 74, 0.1);
		border-radius: 12px;
		color: var(--color-primary);
		margin-bottom: 20px;
	}

	.feature-title {
		font-size: 18px;
		font-weight: 700;
		margin-bottom: 12px;
		letter-spacing: -0.01em;
	}

	.feature-description {
		font-size: 15px;
		line-height: 1.6;
		color: var(--color-text-secondary);
	}

	.features-highlight {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 64px;
		align-items: center;
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 24px;
		padding: 64px;
	}

	.highlight-tag {
		display: inline-block;
		font-size: 13px;
		font-weight: 600;
		color: var(--color-primary);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 16px;
	}

	.highlight-title {
		font-size: clamp(24px, 3vw, 32px);
		font-weight: 800;
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin-bottom: 16px;
	}

	.highlight-description {
		font-size: 16px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin-bottom: 24px;
	}

	.highlight-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.highlight-list li {
		display: flex;
		align-items: center;
		gap: 12px;
		font-size: 15px;
		color: var(--color-text-secondary);
	}

	.highlight-list svg {
		flex-shrink: 0;
	}

	.highlight-visual {
		display: flex;
		justify-content: center;
	}

	.mock-window {
		width: 100%;
		max-width: 400px;
		background: var(--color-bg);
		border-radius: 12px;
		overflow: hidden;
		border: 1px solid var(--color-border);
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
	}

	.mock-header {
		display: flex;
		align-items: center;
		gap: 16px;
		padding: 12px 16px;
		background: var(--color-bg-secondary);
		border-bottom: 1px solid var(--color-border);
	}

	.mock-dots {
		display: flex;
		gap: 6px;
	}

	.mock-dots span {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--color-border-hover);
	}

	.mock-dots span:first-child {
		background: #ff5f57;
	}

	.mock-dots span:nth-child(2) {
		background: #ffbd2e;
	}

	.mock-dots span:last-child {
		background: #28ca42;
	}

	.mock-title {
		font-size: 13px;
		font-weight: 500;
		color: var(--color-text-muted);
	}

	.mock-content {
		padding: 16px;
	}

	.mock-desktop {
		position: relative;
	}

	.mock-input-area {
		padding: 12px 14px;
		background: var(--color-bg-secondary);
		border-radius: 8px;
		font-size: 14px;
		color: var(--color-text);
		line-height: 1.5;
		min-height: 48px;
	}

	.mock-cursor {
		display: inline-block;
		width: 2px;
		height: 16px;
		background: var(--color-primary);
		margin-left: 1px;
		animation: blink 1s infinite;
		vertical-align: text-bottom;
	}

	@keyframes blink {
		0%, 50% { opacity: 1; }
		51%, 100% { opacity: 0; }
	}

	.mock-typed-text {
		color: var(--color-text);
	}

	.voice-control-bubble {
		position: absolute;
		bottom: -20px;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 10px 16px;
		background: rgba(30, 30, 30, 0.95);
		backdrop-filter: blur(20px);
		border-radius: 24px;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.bubble-waveform {
		display: flex;
		align-items: center;
		gap: 3px;
		height: 20px;
	}

	.wave-bar {
		width: 3px;
		background: var(--color-primary);
		border-radius: 2px;
		animation: wave 1s ease-in-out infinite;
	}

	.wave-bar:nth-child(1) { height: 8px; animation-delay: 0s; }
	.wave-bar:nth-child(2) { height: 16px; animation-delay: 0.1s; }
	.wave-bar:nth-child(3) { height: 12px; animation-delay: 0.2s; }
	.wave-bar:nth-child(4) { height: 18px; animation-delay: 0.3s; }
	.wave-bar:nth-child(5) { height: 10px; animation-delay: 0.4s; }

	@keyframes wave {
		0%, 100% { transform: scaleY(1); }
		50% { transform: scaleY(0.5); }
	}

	.bubble-text {
		font-size: 13px;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.9);
		white-space: nowrap;
	}

	@media (max-width: 1024px) {
		.features-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.features-highlight {
			grid-template-columns: 1fr;
			gap: 48px;
			padding: 40px;
		}
	}

	@media (max-width: 768px) {
		.features {
			padding: 80px 0;
		}

		.features-grid {
			grid-template-columns: 1fr;
		}

		.features-highlight {
			padding: 32px;
		}

		.section-description {
			font-size: 16px;
		}
	}
</style>
