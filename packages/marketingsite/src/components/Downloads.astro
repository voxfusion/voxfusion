---
import { defaultLang, type languages, useTranslations } from "../i18n/utils";

interface Props {
	lang?: keyof typeof languages;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const baseUrl = "https://github.com/voxfusion/voxfusion/releases/latest/download";
---

<section class="downloads">
	<div class="downloads-container">
		<div class="section-header">
			<span class="section-number">01</span>
			<h2 class="section-title">DOWNLOADS</h2>
			<div class="section-line"></div>
		</div>

		<div class="section-intro">
			<h1 class="downloads-title">{t("downloads.title")}</h1>
			<p class="downloads-subtitle">{t("downloads.subtitle")}</p>
		</div>

		<div class="platform-section">
			<div class="platform-header">
				<svg class="platform-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
					<path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
				</svg>
				<span class="platform-name">{t("downloads.macos.title")}</span>
			</div>

			<div class="download-grid">
				<div class="download-card">
					<div class="card-index">01</div>
					<div class="card-content">
						<h3 class="card-title">{t("downloads.macos.latest")}</h3>
						<p class="card-description">{t("downloads.macos.latest.description")}</p>
					</div>
					<div class="card-terminal">
						<span class="terminal-prompt">$</span>
						<span class="terminal-command">download --arch=arm64</span>
					</div>
					<a href={`${baseUrl}/VoxFusion-latest.dmg`} class="download-btn" data-umami-event="download_dmg" data-umami-event-variant="apple_silicon">
						<span class="btn-icon">↓</span>
						<span>.dmg</span>
					</a>
				</div>

				<div class="download-card">
					<div class="card-index">02</div>
					<div class="card-content">
						<h3 class="card-title">{t("downloads.macos.intel")}</h3>
						<p class="card-description">{t("downloads.macos.intel.description")}</p>
					</div>
					<div class="card-terminal">
						<span class="terminal-prompt">$</span>
						<span class="terminal-command">download --arch=x86_64</span>
					</div>
					<a href={`${baseUrl}/VoxFusion-latest-intel.dmg`} class="download-btn secondary" data-umami-event="download_dmg" data-umami-event-variant="intel">
						<span class="btn-icon">↓</span>
						<span>.dmg</span>
					</a>
				</div>
			</div>
		</div>

		<div class="platform-section">
			<!-- <div class="platform-header">
				<svg class="platform-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
					<path d="M3 5.548l7.066-.966v6.822H3V5.548zm0 12.904l7.066.966v-6.822H3v5.856zm7.854 1.074L21 21V12.596H10.854v6.93zM10.854 4.474v6.93H21V3l-10.146 1.474z"/>
				</svg>
				<span class="platform-name">{t("downloads.windows.title")}</span>
			</div> -->

			<!-- <div class="warning-banner">
				<span class="warning-icon">[!]</span>
				<span>{t("downloads.windows.warning")}</span>
			</div>

			<div class="download-grid single">
				<div class="download-card">
					<div class="card-index">01</div>
					<div class="card-content">
						<h3 class="card-title">{t("downloads.windows.download")}</h3>
						<p class="card-description">{t("downloads.windows.description")}</p>
					</div>
					<div class="card-terminal">
						<span class="terminal-prompt">></span>
						<span class="terminal-command">download --platform=win</span>
					</div>
					<a href={`${baseUrl}/VoxFusion-latest.exe`} class="download-btn secondary">
						<span class="btn-icon">↓</span>
						<span>.exe</span>
					</a>
				</div>
			</div> -->
		</div>
	</div>
</section>

<style>
	.downloads {
		padding: 140px 32px 120px;
		min-height: 100vh;
		position: relative;
		z-index: 1;
	}

	.downloads-container {
		max-width: 900px;
		margin: 0 auto;
	}

	.section-header {
		display: flex;
		align-items: center;
		gap: 20px;
		margin-bottom: 48px;
	}

	.section-number {
		font-size: 12px;
		color: #ff3e00;
		font-weight: 700;
		font-family: "JetBrains Mono", "Space Mono", monospace;
	}

	.section-title {
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: #666;
		font-family: "JetBrains Mono", "Space Mono", monospace;
	}

	.section-line {
		flex: 1;
		height: 1px;
		background: #222;
	}

	.section-intro {
		margin-bottom: 64px;
	}

	.downloads-title {
		font-size: clamp(32px, 5vw, 48px);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 16px;
		font-family: "JetBrains Mono", "Space Mono", monospace;
	}

	.downloads-subtitle {
		font-size: 14px;
		color: #888;
		line-height: 1.8;
		max-width: 500px;
		font-family: "JetBrains Mono", "Space Mono", monospace;
	}

	.platform-section {
		margin-bottom: 56px;
	}

	.platform-header {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 24px;
		padding-bottom: 16px;
		border-bottom: 1px solid #222;
	}

	.platform-icon {
		color: #ff3e00;
	}

	.platform-name {
		font-size: 14px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #e0e0e0;
		font-family: "JetBrains Mono", "Space Mono", monospace;
	}

	.download-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1px;
		background: #222;
		border: 1px solid #222;
	}

	.download-grid.single {
		grid-template-columns: 1fr;
		max-width: 450px;
	}

	.download-card {
		background: #0a0a0a;
		padding: 32px;
		display: flex;
		flex-direction: column;
		gap: 16px;
		transition: background 0.3s;
	}

	.download-card:hover {
		background: #111;
	}

	.card-index {
		font-size: 11px;
		color: #ff3e00;
		font-weight: 700;
		font-family: "JetBrains Mono", "Space Mono", monospace;
	}

	.card-content {
		flex: 1;
	}

	.card-title {
		font-size: 16px;
		font-weight: 600;
		margin-bottom: 8px;
		font-family: "JetBrains Mono", "Space Mono", monospace;
	}

	.card-description {
		font-size: 13px;
		color: #666;
		line-height: 1.7;
		font-family: "JetBrains Mono", "Space Mono", monospace;
	}

	.card-terminal {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 12px 16px;
		background: #111;
		border: 1px solid #333;
		font-size: 12px;
		font-family: "JetBrains Mono", "Space Mono", monospace;
	}

	.terminal-prompt {
		color: #ff3e00;
	}

	.terminal-command {
		color: #666;
	}

	.download-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		padding: 14px 28px;
		background: #ff3e00;
		color: #000;
		border: 1px solid #ff3e00;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 600;
		transition: all 0.2s;
		text-decoration: none;
		font-family: "JetBrains Mono", "Space Mono", monospace;
	}

	.download-btn:hover {
		background: #fff;
		border-color: #fff;
	}

	.download-btn.secondary {
		background: transparent;
		color: #888;
		border: 1px solid #333;
	}

	.download-btn.secondary:hover {
		color: #fff;
		border-color: #666;
	}

	.btn-icon {
		font-size: 16px;
	}

	.warning-banner {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 14px 20px;
		background: rgba(251, 191, 36, 0.05);
		border: 1px solid rgba(251, 191, 36, 0.3);
		font-size: 13px;
		color: #fbbf24;
		margin-bottom: 24px;
		line-height: 1.5;
		font-family: "JetBrains Mono", "Space Mono", monospace;
	}

	.warning-icon {
		color: #fbbf24;
		font-weight: 700;
	}

	@media (max-width: 768px) {
		.downloads {
			padding: 120px 24px 80px;
		}

		.download-grid {
			grid-template-columns: 1fr;
		}

		.downloads-subtitle {
			font-size: 13px;
		}

		.section-header {
			margin-bottom: 32px;
		}

		.section-intro {
			margin-bottom: 48px;
		}
	}

	@media (max-width: 600px) {
		.downloads {
			padding: 100px 20px 60px;
		}

		.download-card {
			padding: 24px;
		}

		.card-terminal {
			padding: 10px 12px;
			font-size: 11px;
		}
	}
</style>
