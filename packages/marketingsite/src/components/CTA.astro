---
import { useTranslations, defaultLang, languages } from "../i18n/utils";

interface Props {
	lang?: keyof typeof languages;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section id="download" class="cta">
	<div class="container">
		<div class="cta-card">
			<div class="cta-bg">
				<svg class="cta-waveform" viewBox="0 0 800 100" preserveAspectRatio="none">
					<defs>
						<linearGradient id="cta-wave-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
							<stop offset="0%" stop-color="#FF6B4A" stop-opacity="0"/>
							<stop offset="25%" stop-color="#FF6B4A" stop-opacity="0.2"/>
							<stop offset="50%" stop-color="#FF8C69" stop-opacity="0.3"/>
							<stop offset="75%" stop-color="#FF6B4A" stop-opacity="0.2"/>
							<stop offset="100%" stop-color="#FF6B4A" stop-opacity="0"/>
						</linearGradient>
					</defs>
					<path stroke="url(#cta-wave-gradient)" fill="none" stroke-width="2">
						<animate
							attributeName="d"
							dur="3s"
							repeatCount="indefinite"
							values="
								M0,50 Q80,30 160,50 T320,50 T480,50 T640,50 T800,50;
								M0,50 Q80,70 160,50 T320,50 T480,50 T640,50 T800,50;
								M0,50 Q80,30 160,50 T320,50 T480,50 T640,50 T800,50
							"
						/>
					</path>
					<path stroke="url(#cta-wave-gradient)" fill="none" stroke-width="1.5" opacity="0.5">
						<animate
							attributeName="d"
							dur="4s"
							repeatCount="indefinite"
							values="
								M0,50 Q100,35 200,50 T400,50 T600,50 T800,50;
								M0,50 Q100,65 200,50 T400,50 T600,50 T800,50;
								M0,50 Q100,35 200,50 T400,50 T600,50 T800,50
							"
						/>
					</path>
				</svg>
			</div>

			<div class="cta-content">
				<h2 class="cta-title">{t("cta.title")}</h2>
				<p class="cta-description">
					{t("cta.description")}
				</p>
				<div class="cta-actions">
					<a href="https://github.com/gregor-tokarev/voxfusion-releases/releases/latest/download/VoxFusion-latest.dmg" class="cta-btn primary">
						<svg width="20" height="20" viewBox="0 0 20 20" fill="none">
							<path d="M10 3V17M10 17L4 11M10 17L16 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
						<span>{t("cta.button")}</span>
					</a>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.cta {
		padding: 120px 0 80px;
		background: var(--color-bg-secondary);
	}

	.cta-card {
		position: relative;
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 32px;
		padding: 80px 48px;
		text-align: center;
		overflow: hidden;
	}

	.cta-bg {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		pointer-events: none;
	}

	.cta-waveform {
		width: 100%;
		height: 100px;
		opacity: 0.5;
	}

	.cta-content {
		position: relative;
		z-index: 2;
	}

	.cta-title {
		font-size: clamp(32px, 5vw, 48px);
		font-weight: 800;
		letter-spacing: -0.02em;
		margin-bottom: 16px;
	}

	.cta-description {
		font-size: 18px;
		color: var(--color-text-secondary);
		margin-bottom: 32px;
	}

	.cta-actions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 20px;
	}

	.cta-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		padding: 16px 32px;
		border-radius: 14px;
		font-size: 17px;
		font-weight: 600;
		transition: all 0.2s ease;
	}

	.cta-btn.primary {
		background: var(--color-primary);
		color: white;
	}

	.cta-btn.primary:hover {
		background: var(--color-primary-dark);
		transform: translateY(-2px);
		box-shadow: 0 12px 32px rgba(255, 107, 74, 0.35);
	}

	@media (max-width: 768px) {
		.cta {
			padding: 80px 0 60px;
		}

		.cta-card {
			padding: 60px 24px;
			border-radius: 24px;
		}

		.cta-description {
			font-size: 16px;
		}

		.cta-btn {
			width: 100%;
		}
	}
</style>
