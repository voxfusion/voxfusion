---
import { defaultLang, getLocalizedPath, useTranslations } from "../i18n/utils";
import BaseLayout from "../layouts/BaseLayout.astro";

const lang = defaultLang;
const t = useTranslations(lang);
const title = `${t("security.title")} - VoxFusion`;
const description = t("security.meta.description");
---

<BaseLayout
	title={title}
	description={description}
	lang={lang}
	showNavLinks
	ctaHref={getLocalizedPath("/", lang)}
	ctaLabel={t("legal.backToHome")}
>
	<main class="legal-page">
		<div class="legal-header">
			<span class="section-number">§</span>
			<h1>{t("security.title")}</h1>
			<p class="last-updated">{t("security.lastUpdated")}</p>
		</div>

		<div class="legal-content">
			<p class="intro">{t("security.intro")}</p>

			<section>
				<h2>{t("security.section1.title")}</h2>
				<p>{t("security.section1.p1")}</p>
				<p>{t("security.section1.p2")}</p>
				<p>{t("security.section1.p3")}</p>
			</section>

			<section>
				<h2>{t("security.section2.title")}</h2>
				<p>{t("security.section2.p1")}</p>
				<p>{t("security.section2.p2")}</p>
				<p>{t("security.section2.p3")}</p>
			</section>

			<section>
				<h2>{t("security.section3.title")}</h2>
				<p>{t("security.section3.p1")}</p>
				<p>{t("security.section3.p2")}</p>
				<p>{t("security.section3.p3")}</p>
			</section>

			<section>
				<h2>{t("security.section4.title")}</h2>
				<p>{t("security.section4.p1")}</p>
				<p>{t("security.section4.p2")}</p>
			</section>

			<section>
				<h2>{t("security.section5.title")}</h2>
				<p>{t("security.section5.p1")}</p>
				<p>{t("security.section5.p2")}</p>
			</section>
		</div>

		<div class="legal-footer">
			<a href={getLocalizedPath("/", lang)} class="back-link">{t("legal.backToHome")}</a>
		</div>
	</main>
</BaseLayout>

<style>
	.legal-page {
		max-width: 800px;
		margin: 0 auto;
		padding: 120px 32px 80px;
	}

	.legal-header {
		margin-bottom: 48px;
		padding-bottom: 32px;
		border-bottom: 1px solid #222;
	}

	.section-number {
		font-size: 14px;
		color: #ff3e00;
		font-weight: 700;
		display: block;
		margin-bottom: 16px;
	}

	.legal-header h1 {
		font-size: clamp(28px, 4vw, 40px);
		font-weight: 700;
		margin-bottom: 12px;
	}

	.last-updated {
		font-size: 13px;
		color: #666;
	}

	.legal-content {
		display: flex;
		flex-direction: column;
		gap: 40px;
	}

	.intro {
		font-size: 14px;
		color: #888;
		line-height: 1.8;
		padding: 24px;
		border-left: 2px solid #ff3e00;
		background: rgba(255, 62, 0, 0.03);
	}

	.legal-content section {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.legal-content h2 {
		font-size: 16px;
		font-weight: 600;
		color: #fff;
		padding-bottom: 8px;
		border-bottom: 1px solid #1a1a1a;
	}

	.legal-content p {
		font-size: 13px;
		color: #888;
		line-height: 1.8;
	}

	.legal-footer {
		margin-top: 64px;
		padding-top: 32px;
		border-top: 1px solid #222;
	}

	.back-link {
		font-size: 13px;
		color: #ff3e00;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: color 0.2s;
	}

	.back-link:hover {
		color: #fff;
	}

	@media (max-width: 768px) {
		.legal-page {
			padding: 100px 24px 60px;
		}
	}
</style>
