---
import Footer from "../components/Footer.astro";
import Umami from "../components/Umami.astro";
import { useTranslations, defaultLang, getLocalizedPath } from "../i18n/utils";
import Seo from "../components/Seo.astro";

const lang = defaultLang;
const t = useTranslations(lang);
const title = `${t("privacy.title")} - VoxFusion`;
const description = title;
---

<!doctype html>
<html lang={lang}>
<head>
	<meta charset="UTF-8" />
	<Seo title={title} description={description} lang={lang} />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
	<title>{title}</title>
</head>
<body>
	<div class="grid-overlay"></div>

	<nav class="nav">
		<div class="nav-inner">
			<a href={getLocalizedPath("/", lang)} class="logo">
				<span class="logo-bracket">[</span>VOX<span class="logo-accent">FUSION</span><span class="logo-bracket">]</span>
			</a>
			<div class="nav-links">
				<a href={getLocalizedPath("/", lang) + "#features"} class="nav-link"><span class="link-index">01</span>{t("nav.features")}</a>
				<a href="https://github.com/voxfusion/voxfusion" target="_blank" rel="noopener noreferrer" class="nav-link"><span class="link-index">02</span>{t("nav.github")}</a>
			</div>
			<a href={getLocalizedPath("/", lang)} class="nav-cta">{t("legal.backToHome")}</a>
		</div>
	</nav>

	<main class="legal-page">
		<div class="legal-header">
			<span class="section-number">§</span>
			<h1>{t("privacy.title")}</h1>
			<p class="last-updated">{t("privacy.lastUpdated")}</p>
		</div>

		<div class="legal-content">
			<p class="intro">{t("privacy.intro")}</p>

			<section>
				<h2>{t("privacy.section1.title")}</h2>
				<p>{t("privacy.section1.p1")}</p>
				<p>{t("privacy.section1.p2")}</p>
				<p>{t("privacy.section1.p3")}</p>
			</section>

			<section>
				<h2>{t("privacy.section2.title")}</h2>
				<p>{t("privacy.section2.p1")}</p>
				<p>{t("privacy.section2.p2")}</p>
				<p>{t("privacy.section2.p3")}</p>
				<p>{t("privacy.section2.p4")}</p>
			</section>

			<section>
				<h2>{t("privacy.section3.title")}</h2>
				<p>{t("privacy.section3.p1")}</p>
				<p>{t("privacy.section3.p2")}</p>
			</section>

			<section>
				<h2>{t("privacy.section4.title")}</h2>
				<p>{t("privacy.section4.p1")}</p>
				<p>{t("privacy.section4.p2")}</p>
				<p>{t("privacy.section4.p3")}</p>
			</section>

			<section>
				<h2>{t("privacy.section5.title")}</h2>
				<p>{t("privacy.section5.p1")}</p>
			</section>

			<section>
				<h2>{t("privacy.section6.title")}</h2>
				<p>{t("privacy.section6.p1")}</p>
				<p>{t("privacy.section6.p2")}</p>
				<p>{t("privacy.section6.p3")}</p>
				<p>{t("privacy.section6.p4")}</p>
			</section>

			<section>
				<h2>{t("privacy.section7.title")}</h2>
				<p>{t("privacy.section7.p1")}</p>
				<p>{t("privacy.section7.p2")}</p>
				<p>{t("privacy.section7.p3")}</p>
			</section>

			<section>
				<h2>{t("privacy.section8.title")}</h2>
				<p>{t("privacy.section8.p1")}</p>
				<p>{t("privacy.section8.p2")}</p>
			</section>

			<section>
				<h2>{t("privacy.section9.title")}</h2>
				<p>{t("privacy.section9.p1")}</p>
			</section>
		</div>

		<div class="legal-footer">
			<a href={getLocalizedPath("/", lang)} class="back-link">{t("legal.backToHome")}</a>
		</div>
	</main>

	<Footer lang={lang} />
	<Umami />
</body>
</html>

<style>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	a {
		text-decoration: none;
		color: inherit;
	}

	html {
		font-family: "JetBrains Mono", "Space Mono", monospace;
		background: #0a0a0a;
		color: #e0e0e0;
		scroll-behavior: smooth;
		font-size: 15px;
	}

	body {
		min-height: 100vh;
		position: relative;
	}

	.grid-overlay {
		position: fixed;
		inset: 0;
		background-image:
			linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
		background-size: 40px 40px;
		pointer-events: none;
		z-index: 0;
	}

	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		border-bottom: 1px solid #222;
		background: rgba(10, 10, 10, 0.95);
		backdrop-filter: blur(10px);
	}

	.nav-inner {
		max-width: 1400px;
		margin: 0 auto;
		padding: 16px 32px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		font-size: 18px;
		font-weight: 700;
		letter-spacing: 0.1em;
		color: #e0e0e0;
	}

	.logo-bracket { color: #ff3e00; }
	.logo-accent { color: #666; }

	.nav-links {
		display: flex;
		gap: 32px;
	}

	.nav-link {
		font-size: 13px;
		color: #888;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: color 0.2s;
	}

	.nav-link:hover { color: #fff; }

	.link-index {
		color: #ff3e00;
		margin-right: 8px;
	}

	.nav-cta {
		padding: 10px 20px;
		border: 1px solid #ff3e00;
		color: #ff3e00;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: all 0.2s;
	}

	.nav-cta:hover {
		background: #ff3e00;
		color: #000;
	}

	.legal-page {
		max-width: 800px;
		margin: 0 auto;
		padding: 120px 32px 80px;
	}

	.legal-header {
		margin-bottom: 48px;
		padding-bottom: 32px;
		border-bottom: 1px solid #222;
	}

	.section-number {
		font-size: 14px;
		color: #ff3e00;
		font-weight: 700;
		display: block;
		margin-bottom: 16px;
	}

	.legal-header h1 {
		font-size: clamp(28px, 4vw, 40px);
		font-weight: 700;
		margin-bottom: 12px;
	}

	.last-updated {
		font-size: 13px;
		color: #666;
	}

	.legal-content {
		display: flex;
		flex-direction: column;
		gap: 40px;
	}

	.intro {
		font-size: 14px;
		color: #888;
		line-height: 1.8;
		padding: 24px;
		border-left: 2px solid #ff3e00;
		background: rgba(255, 62, 0, 0.03);
	}

	.legal-content section {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.legal-content h2 {
		font-size: 16px;
		font-weight: 600;
		color: #fff;
		padding-bottom: 8px;
		border-bottom: 1px solid #1a1a1a;
	}

	.legal-content p {
		font-size: 13px;
		color: #888;
		line-height: 1.8;
	}

	.legal-footer {
		margin-top: 64px;
		padding-top: 32px;
		border-top: 1px solid #222;
	}

	.back-link {
		font-size: 13px;
		color: #ff3e00;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: color 0.2s;
	}

	.back-link:hover {
		color: #fff;
	}

	@media (max-width: 768px) {
		.nav-links {
			display: none;
		}

		.legal-page {
			padding: 100px 24px 60px;
		}
	}
</style>
