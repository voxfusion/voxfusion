---
/**
 * 404 PAGE: BRUTALIST / RAW INDUSTRIAL
 *
 * Design Direction: Raw, industrial, unapologetic. Exposed grid structures,
 * monospace typography, harsh contrasts, visible construction elements.
 * Think concrete architecture meets command-line interfaces.
 */
import { useTranslations, defaultLang, getLocalizedPath } from "../i18n/utils";

const lang = defaultLang;
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
<head>
	<meta charset="UTF-8" />
	<meta name="description" content={t("notFound.description")} />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
	<title>404 - {t("notFound.title")}</title>
</head>
<body>
	<div class="grid-overlay"></div>

	<nav class="nav">
		<div class="nav-inner">
			<a href={getLocalizedPath("/", lang)} class="logo">
				<span class="logo-bracket">[</span>VOX<span class="logo-accent">FUSION</span><span class="logo-bracket">]</span>
			</a>
		</div>
	</nav>

	<main class="error-page">
		<div class="error-container">
			<div class="terminal">
				<div class="terminal-header">
					<span class="terminal-title">~ system/error</span>
					<div class="terminal-controls">
						<span></span><span></span><span></span>
					</div>
				</div>
				<div class="terminal-body">
					<div class="terminal-line">
						<span class="prompt">$</span>
						<span class="command">locate --page</span>
					</div>
					<div class="terminal-line output">
						<span class="status error">[ERROR_404]</span> PAGE_NOT_FOUND
					</div>
					<div class="terminal-line output">
						<span class="timestamp">[{new Date().toISOString().slice(0, 19).replace('T', ' ')}]</span>
					</div>
					<div class="terminal-line">
						<span class="prompt">$</span>
						<span class="cursor">_</span>
					</div>
				</div>
			</div>

			<div class="error-content">
				<div class="error-code">404</div>
				<h1 class="error-title">{t("notFound.title")}</h1>
				<p class="error-description">{t("notFound.description")}</p>
				<a href={getLocalizedPath("/", lang)} class="error-cta">
					<span class="cta-icon">&larr;</span>
					<span>{t("notFound.cta")}</span>
				</a>
			</div>

			<div class="glitch-lines">
				{[...Array(5)].map((_, i) => (
					<div class="glitch-line" style={`--delay: ${i * 0.2}s; --offset: ${(i - 2) * 15}px`}></div>
				))}
			</div>
		</div>
	</main>

	<footer class="footer">
		<div class="footer-inner">
			<span>&copy; 2025 VoxFusion</span>
			<span class="status"><span class="status-dot"></span> All systems operational</span>
		</div>
	</footer>
</body>
</html>

<style>
	@keyframes blink {
		0%, 50% { opacity: 1; }
		51%, 100% { opacity: 0; }
	}

	@keyframes glitch {
		0%, 100% { transform: translateX(0); opacity: 0; }
		10% { transform: translateX(var(--offset)); opacity: 0.5; }
		20% { transform: translateX(calc(var(--offset) * -0.5)); opacity: 0.3; }
		30% { transform: translateX(0); opacity: 0; }
	}

	@keyframes pulse {
		0%, 100% { opacity: 0.5; }
		50% { opacity: 1; }
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		font-family: "JetBrains Mono", "Space Mono", monospace;
		background: #0a0a0a;
		color: #e0e0e0;
		font-size: 15px;
	}

	body {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		position: relative;
	}

	.grid-overlay {
		position: fixed;
		inset: 0;
		background-image:
			linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
		background-size: 40px 40px;
		pointer-events: none;
		z-index: 0;
	}

	/* Navigation */
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		border-bottom: 1px solid #222;
		background: rgba(10, 10, 10, 0.95);
		backdrop-filter: blur(10px);
	}

	.nav-inner {
		max-width: 1400px;
		margin: 0 auto;
		padding: 16px 32px;
		display: flex;
		align-items: center;
	}

	.logo {
		font-size: 18px;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-decoration: none;
		color: inherit;
	}

	.logo-bracket {
		color: #ff3e00;
	}

	.logo-accent {
		color: #666;
	}

	/* Error Page */
	.error-page {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 120px 32px 60px;
		position: relative;
		z-index: 1;
	}

	.error-container {
		max-width: 600px;
		width: 100%;
		position: relative;
	}

	/* Terminal */
	.terminal {
		background: #111;
		border: 1px solid #333;
		border-radius: 4px;
		overflow: hidden;
		margin-bottom: 48px;
	}

	.terminal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 12px 16px;
		background: #1a1a1a;
		border-bottom: 1px solid #333;
	}

	.terminal-title {
		font-size: 12px;
		color: #666;
	}

	.terminal-controls {
		display: flex;
		gap: 8px;
	}

	.terminal-controls span {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: #333;
	}

	.terminal-body {
		padding: 20px;
		font-size: 13px;
		line-height: 2;
	}

	.terminal-line {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.prompt {
		color: #ff3e00;
	}

	.command {
		color: #fff;
	}

	.output {
		color: #666;
	}

	.status.error {
		color: #ff3e00;
		animation: pulse 2s ease-in-out infinite;
	}

	.timestamp {
		color: #444;
		font-size: 11px;
	}

	.cursor {
		animation: blink 1s infinite;
		color: #ff3e00;
	}

	/* Error Content */
	.error-content {
		text-align: center;
	}

	.error-code {
		font-size: clamp(80px, 15vw, 140px);
		font-weight: 800;
		line-height: 1;
		color: transparent;
		-webkit-text-stroke: 2px #ff3e00;
		letter-spacing: -0.04em;
		margin-bottom: 24px;
		position: relative;
	}

	.error-code::after {
		content: '404';
		position: absolute;
		top: 4px;
		left: 50%;
		transform: translateX(-50%);
		-webkit-text-stroke: 1px rgba(255, 62, 0, 0.3);
		z-index: -1;
	}

	.error-title {
		font-size: 12px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: #888;
		margin-bottom: 16px;
	}

	.error-description {
		font-size: 14px;
		color: #666;
		line-height: 1.8;
		max-width: 400px;
		margin: 0 auto 40px;
	}

	.error-cta {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		padding: 14px 28px;
		background: transparent;
		color: #ff3e00;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 600;
		border: 1px solid #ff3e00;
		text-decoration: none;
		transition: all 0.2s;
	}

	.error-cta:hover {
		background: #ff3e00;
		color: #000;
	}

	.cta-icon {
		font-size: 18px;
	}

	/* Glitch Effect */
	.glitch-lines {
		position: absolute;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
	}

	.glitch-line {
		position: absolute;
		top: 50%;
		left: -10%;
		right: -10%;
		height: 2px;
		background: linear-gradient(90deg, transparent, #ff3e00, transparent);
		opacity: 0;
		animation: glitch 4s ease-in-out infinite;
		animation-delay: var(--delay);
	}

	/* Footer */
	.footer {
		border-top: 1px solid #222;
		padding: 20px 32px;
		position: relative;
		z-index: 1;
	}

	.footer-inner {
		max-width: 1400px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		font-size: 12px;
		color: #666;
	}

	.status {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.status-dot {
		width: 8px;
		height: 8px;
		background: #00ff88;
		border-radius: 50%;
	}

	/* Responsive */
	@media (max-width: 600px) {
		.error-page {
			padding: 100px 20px 40px;
		}

		.terminal-body {
			padding: 16px;
			font-size: 12px;
		}

		.error-code {
			-webkit-text-stroke-width: 1.5px;
		}

		.footer-inner {
			flex-direction: column;
			gap: 12px;
			align-items: center;
		}
	}
</style>
