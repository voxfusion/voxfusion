---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import { useTranslations, defaultLang, getLocalizedPath } from "../i18n/utils";

const lang = defaultLang;
const t = useTranslations(lang);
---

<Layout title={`404 - ${t("notFound.title")}`} lang={lang}>
	<nav class="nav">
		<div class="container nav-container">
			<a href={getLocalizedPath("/", lang)} class="logo">
				<div class="logo-icon">
					<svg width="32" height="32" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
						<defs>
							<linearGradient id="logo-wg-404" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#6366f1"/><stop offset="50%" stop-color="#8b5cf6"/><stop offset="100%" stop-color="#a855f7"/></linearGradient>
							<linearGradient id="logo-wg2-404" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#8b5cf6"/><stop offset="100%" stop-color="#c084fc"/></linearGradient>
							<linearGradient id="logo-wg3-404" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#a855f7"/><stop offset="100%" stop-color="#d8b4fe"/></linearGradient>
						</defs>
						<rect x="5" y="5" width="190" height="190" rx="38" ry="38" fill="#0f0f23"/>
						<rect x="25" y="45" width="8" height="35" rx="4" fill="url(#logo-wg3-404)" opacity="0.7"/>
						<rect x="42" y="55" width="8" height="50" rx="4" fill="url(#logo-wg2-404)" opacity="0.8"/>
						<rect x="59" y="70" width="8" height="55" rx="4" fill="url(#logo-wg-404)" opacity="0.9"/>
						<rect x="76" y="85" width="8" height="60" rx="4" fill="url(#logo-wg-404)"/>
						<rect x="96" y="110" width="8" height="55" rx="4" fill="url(#logo-wg-404)"/>
						<rect x="116" y="85" width="8" height="60" rx="4" fill="url(#logo-wg-404)"/>
						<rect x="133" y="70" width="8" height="55" rx="4" fill="url(#logo-wg-404)" opacity="0.9"/>
						<rect x="150" y="55" width="8" height="50" rx="4" fill="url(#logo-wg2-404)" opacity="0.8"/>
						<rect x="167" y="45" width="8" height="35" rx="4" fill="url(#logo-wg3-404)" opacity="0.7"/>
					</svg>
				</div>
				<span class="logo-text">VoxFusion</span>
			</a>
		</div>
	</nav>

	<main class="not-found">
		<div class="container not-found-content">
			<div class="error-code">404</div>
			<h1 class="not-found-title">{t("notFound.title")}</h1>
			<p class="not-found-description">{t("notFound.description")}</p>
			<a href={getLocalizedPath("/", lang)} class="btn btn-primary btn-lg">
				<svg width="20" height="20" viewBox="0 0 20 20" fill="none">
					<path d="M16 10H4M4 10L9 5M4 10L9 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
				<span>{t("notFound.cta")}</span>
			</a>
		</div>

		<div class="not-found-visual">
			<svg class="waveform-svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
				<defs>
					<linearGradient id="nf-wave-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
						<stop offset="0%" stop-color="#FF6B4A" stop-opacity="0"/>
						<stop offset="20%" stop-color="#FF6B4A" stop-opacity="0.3"/>
						<stop offset="50%" stop-color="#FF8C69" stop-opacity="0.4"/>
						<stop offset="80%" stop-color="#FF6B4A" stop-opacity="0.3"/>
						<stop offset="100%" stop-color="#FF6B4A" stop-opacity="0"/>
					</linearGradient>
				</defs>
				<path stroke="url(#nf-wave-gradient)" fill="none" stroke-width="2" opacity="0.5">
					<animate
						attributeName="d"
						dur="4s"
						repeatCount="indefinite"
						values="
							M0,60 Q100,30 200,60 T400,60 T600,60 T800,60 T1000,60 T1200,60;
							M0,60 Q100,90 200,60 T400,60 T600,60 T800,60 T1000,60 T1200,60;
							M0,60 Q100,30 200,60 T400,60 T600,60 T800,60 T1000,60 T1200,60
						"
					/>
				</path>
				<path stroke="url(#nf-wave-gradient)" fill="none" stroke-width="1.5" opacity="0.3">
					<animate
						attributeName="d"
						dur="5s"
						repeatCount="indefinite"
						values="
							M0,60 Q200,45 400,60 T800,60 T1200,60;
							M0,60 Q200,75 400,60 T800,60 T1200,60;
							M0,60 Q200,45 400,60 T800,60 T1200,60
						"
					/>
				</path>
			</svg>
			<div class="not-found-glow"></div>
		</div>
	</main>

	<Footer lang={lang} />
</Layout>

<style>
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		padding: 16px 0;
		background: rgba(10, 22, 40, 0.8);
		backdrop-filter: blur(20px);
		border-bottom: 1px solid var(--color-border);
	}

	.nav-container {
		display: flex;
		align-items: center;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.logo-text {
		font-weight: 700;
		font-size: 20px;
		letter-spacing: -0.02em;
	}

	.not-found {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
	}

	.not-found-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		position: relative;
		z-index: 2;
	}

	.error-code {
		font-size: clamp(100px, 20vw, 200px);
		font-weight: 900;
		line-height: 1;
		letter-spacing: -0.04em;
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 50%, var(--color-accent-light) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 16px;
		opacity: 0.9;
	}

	.not-found-title {
		font-size: clamp(24px, 4vw, 36px);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 12px;
	}

	.not-found-description {
		font-size: 17px;
		line-height: 1.6;
		color: var(--color-text-secondary);
		max-width: 440px;
		margin-bottom: 32px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		padding: 10px 20px;
		border-radius: 10px;
		font-size: 15px;
		font-weight: 600;
		transition: all 0.2s ease;
	}

	.btn-primary {
		background: var(--color-primary);
		color: white;
	}

	.btn-primary:hover {
		background: var(--color-primary-dark);
		transform: translateY(-1px);
		box-shadow: 0 8px 24px rgba(255, 107, 74, 0.3);
	}

	.btn-lg {
		padding: 14px 28px;
		font-size: 16px;
		border-radius: 12px;
	}

	.not-found-visual {
		position: absolute;
		bottom: 60px;
		left: 0;
		right: 0;
		height: 120px;
		pointer-events: none;
	}

	.waveform-svg {
		width: 100%;
		height: 100%;
	}

	.not-found-glow {
		position: absolute;
		top: -100px;
		left: 50%;
		transform: translateX(-50%);
		width: 500px;
		height: 300px;
		background: radial-gradient(ellipse at center, rgba(255, 107, 74, 0.08) 0%, transparent 70%);
		pointer-events: none;
	}

	@media (max-width: 600px) {
		.not-found-description {
			font-size: 15px;
		}

		.not-found-visual {
			height: 80px;
			bottom: 40px;
		}
	}
</style>
