---
/**
 * 404 PAGE: BRUTALIST / RAW INDUSTRIAL
 *
 * Design Direction: Raw, industrial, unapologetic. Exposed grid structures,
 * monospace typography, harsh contrasts, visible construction elements.
 * Think concrete architecture meets command-line interfaces.
 */

import { defaultLang, getLocalizedPath, useTranslations } from "../i18n/utils";
import BaseLayout from "../layouts/BaseLayout.astro";

const lang = defaultLang;
const t = useTranslations(lang);
const title = `404 - ${t("notFound.title")}`;
const description = t("notFound.description");
---

<BaseLayout
	title={title}
	description={description}
	lang={lang}
	noindex
	bodyClass="not-found"
	showFooter={false}
>
	<main class="error-page">
		<div class="error-container">
			<div class="terminal">
				<div class="terminal-header">
					<span class="terminal-title">~ system/error</span>
					<div class="terminal-controls">
						<span></span><span></span><span></span>
					</div>
				</div>
				<div class="terminal-body">
					<div class="terminal-line">
						<span class="prompt">$</span>
						<span class="command">locate --page</span>
					</div>
					<div class="terminal-line output">
						<span class="status error">[ERROR_404]</span> PAGE_NOT_FOUND
					</div>
					<div class="terminal-line output">
						<span class="timestamp">[{new Date().toISOString().slice(0, 19).replace('T', ' ')}]</span>
					</div>
					<div class="terminal-line">
						<span class="prompt">$</span>
						<span class="cursor">_</span>
					</div>
				</div>
			</div>

			<div class="error-content">
				<div class="error-code">404</div>
				<h1 class="error-title">{t("notFound.title")}</h1>
				<p class="error-description">{t("notFound.description")}</p>
				<a href={getLocalizedPath("/", lang)} class="error-cta">
					<span class="cta-icon">&larr;</span>
					<span>{t("notFound.cta")}</span>
				</a>
			</div>

			<div class="glitch-lines">
				{[...Array(5)].map((_, i) => (
					<div class="glitch-line" style={`--delay: ${i * 0.2}s; --offset: ${(i - 2) * 15}px`}></div>
				))}
			</div>
		</div>
	</main>

	<footer class="footer">
		<div class="footer-inner">
			<span>&copy; 2025 VoxFusion</span>
			<span class="status"><span class="status-dot"></span> All systems operational</span>
		</div>
	</footer>
</BaseLayout>

<style is:global>
	body.not-found {
		display: flex;
		flex-direction: column;
	}
</style>

<style>
	@keyframes blink {
		0%, 50% { opacity: 1; }
		51%, 100% { opacity: 0; }
	}

	@keyframes glitch {
		0%, 100% { transform: translateX(0); opacity: 0; }
		10% { transform: translateX(var(--offset)); opacity: 0.5; }
		20% { transform: translateX(calc(var(--offset) * -0.5)); opacity: 0.3; }
		30% { transform: translateX(0); opacity: 0; }
	}

	@keyframes pulse {
		0%, 100% { opacity: 0.5; }
		50% { opacity: 1; }
	}

	/* Error Page */
	.error-page {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 120px 32px 60px;
		position: relative;
		z-index: 1;
	}

	.error-container {
		max-width: 600px;
		width: 100%;
		position: relative;
	}

	/* Terminal */
	.terminal {
		background: #111;
		border: 1px solid #333;
		border-radius: 4px;
		overflow: hidden;
		margin-bottom: 48px;
	}

	.terminal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 12px 16px;
		background: #1a1a1a;
		border-bottom: 1px solid #333;
	}

	.terminal-title {
		font-size: 12px;
		color: #666;
	}

	.terminal-controls {
		display: flex;
		gap: 8px;
	}

	.terminal-controls span {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: #333;
	}

	.terminal-body {
		padding: 20px;
		font-size: 13px;
		line-height: 2;
	}

	.terminal-line {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.prompt {
		color: #ff3e00;
	}

	.command {
		color: #fff;
	}

	.output {
		color: #666;
	}

	.status.error {
		color: #ff3e00;
		animation: pulse 2s ease-in-out infinite;
	}

	.timestamp {
		color: #444;
		font-size: 11px;
	}

	.cursor {
		animation: blink 1s infinite;
		color: #ff3e00;
	}

	/* Error Content */
	.error-content {
		text-align: center;
	}

	.error-code {
		font-size: clamp(80px, 15vw, 140px);
		font-weight: 800;
		line-height: 1;
		color: transparent;
		-webkit-text-stroke: 2px #ff3e00;
		letter-spacing: -0.04em;
		margin-bottom: 24px;
		position: relative;
	}

	.error-code::after {
		content: '404';
		position: absolute;
		top: 4px;
		left: 50%;
		transform: translateX(-50%);
		-webkit-text-stroke: 1px rgba(255, 62, 0, 0.3);
		z-index: -1;
	}

	.error-title {
		font-size: 12px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: #888;
		margin-bottom: 16px;
	}

	.error-description {
		font-size: 14px;
		color: #666;
		line-height: 1.8;
		max-width: 400px;
		margin: 0 auto 40px;
	}

	.error-cta {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		padding: 14px 28px;
		background: transparent;
		color: #ff3e00;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 600;
		border: 1px solid #ff3e00;
		text-decoration: none;
		transition: all 0.2s;
	}

	.error-cta:hover {
		background: #ff3e00;
		color: #000;
	}

	.cta-icon {
		font-size: 18px;
	}

	/* Glitch Effect */
	.glitch-lines {
		position: absolute;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
	}

	.glitch-line {
		position: absolute;
		top: 50%;
		left: -10%;
		right: -10%;
		height: 2px;
		background: linear-gradient(90deg, transparent, #ff3e00, transparent);
		opacity: 0;
		animation: glitch 4s ease-in-out infinite;
		animation-delay: var(--delay);
	}

	/* Footer */
	.footer {
		border-top: 1px solid #222;
		padding: 20px 32px;
		position: relative;
		z-index: 1;
	}

	.footer-inner {
		max-width: 1400px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		font-size: 12px;
		color: #666;
	}

	.status {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.status-dot {
		width: 8px;
		height: 8px;
		background: #00ff88;
		border-radius: 50%;
	}

	/* Responsive */
	@media (max-width: 600px) {
		.error-page {
			padding: 100px 20px 40px;
		}

		.terminal-body {
			padding: 16px;
			font-size: 12px;
		}

		.error-code {
			-webkit-text-stroke-width: 1.5px;
		}

		.footer-inner {
			flex-direction: column;
			gap: 12px;
			align-items: center;
		}
	}
</style>
