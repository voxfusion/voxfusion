---
import Downloads from "../components/Downloads.astro";
import { defaultLang, getLocalizedPath, useTranslations } from "../i18n/utils";
import BaseLayout from "../layouts/BaseLayout.astro";
import { softwareApplicationSchema } from "../seo";

const lang = defaultLang;
const t = useTranslations(lang);
const title = t("downloads.meta.title");
const description = t("downloads.meta.description");
const schema = softwareApplicationSchema(description);
---

<BaseLayout
	title={title}
	description={description}
	lang={lang}
	schema={schema}
	showNavLinks
	ctaHref={getLocalizedPath("/", lang)}
	ctaLabel={`${t("nav.features")} →`}
>
	<Fragment slot="nav-extra">
		<button class="mobile-menu-btn" aria-label="Toggle menu">
			<span></span>
			<span></span>
			<span></span>
		</button>

		<div class="mobile-menu">
			<div class="mobile-menu-links">
				<a href={getLocalizedPath("/", lang)}>{t("nav.features")}</a>
			</div>
		</div>
	</Fragment>

	<Downloads lang={lang} />
</BaseLayout>

<style>
	.mobile-menu-btn {
		display: none;
		flex-direction: column;
		gap: 5px;
		padding: 8px;
		background: none;
		border: none;
		cursor: pointer;
	}

	.mobile-menu-btn span {
		width: 24px;
		height: 2px;
		background: #e0e0e0;
		border-radius: 2px;
		transition: all 0.2s;
	}

	.mobile-menu {
		display: none;
		flex-direction: column;
		gap: 24px;
		padding: 24px 32px;
		border-top: 1px solid #222;
		background: rgba(10, 10, 10, 0.98);
	}

	.mobile-menu.open {
		display: flex;
	}

	.mobile-menu-links {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.mobile-menu-links a {
		font-size: 14px;
		font-weight: 500;
		color: #888;
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: color 0.2s ease;
	}

	.mobile-menu-links a:hover {
		color: #ff3e00;
	}

	.mobile-menu-btn.open span:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}

	.mobile-menu-btn.open span:nth-child(2) {
		opacity: 0;
	}

	.mobile-menu-btn.open span:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	@media (max-width: 768px) {
		:global(.nav-cta) {
			display: none;
		}

		.mobile-menu-btn {
			display: flex;
		}

		:global(.nav-inner) {
			padding: 16px 24px;
		}
	}
</style>

<script>
	const menuBtn = document.querySelector('.mobile-menu-btn');
	const mobileMenu = document.querySelector('.mobile-menu');

	menuBtn?.addEventListener('click', () => {
		menuBtn.classList.toggle('open');
		mobileMenu?.classList.toggle('open');
	});

	mobileMenu?.querySelectorAll('a').forEach((link) => {
		link.addEventListener('click', () => {
			menuBtn?.classList.remove('open');
			mobileMenu?.classList.remove('open');
		});
	});
</script>
