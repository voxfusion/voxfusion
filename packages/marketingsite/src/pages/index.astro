---
/**
 * VERSION 1: BRUTALIST / RAW INDUSTRIAL
 *
 * Design Direction: Raw, industrial, unapologetic. Exposed grid structures,
 * monospace typography, harsh contrasts, visible construction elements.
 * Think concrete architecture meets command-line interfaces.
 */
import { useTranslations, defaultLang, getLocalizedPath } from "../i18n/utils";
import YandexMetrika from "../components/YandexMetrika.astro";

const lang = defaultLang;
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
<head>
	<meta charset="UTF-8" />
	<meta name="description" content={t("meta.description")} />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
	<title>{t("meta.title")}</title>
</head>
<body>
	<div class="grid-overlay"></div>

	<nav class="nav">
		<div class="nav-inner">
			<a href="/" class="logo">
				<span class="logo-bracket">[</span>VOX<span class="logo-accent">FUSION</span><span class="logo-bracket">]</span>
			</a>
			<div class="nav-links">
				<a href="#features" class="nav-link"><span class="link-index">01</span>{t("nav.features")}</a>
				<a href="#demo" class="nav-link"><span class="link-index">02</span>{t("nav.demo")}</a>
				<a href="#pricing" class="nav-link"><span class="link-index">03</span>{t("nav.pricing")}</a>
			</div>
			<a href={getLocalizedPath("/download", lang)} class="nav-cta">{t("nav.download")} →</a>
		</div>
	</nav>

	<header class="hero">
		<div class="hero-grid">
			<div class="hero-content">
				<div class="hero-label">
					<span class="label-line"></span>
					<span class="label-text">VOICE_TO_TEXT.EXE</span>
				</div>
				<h1 class="hero-title">
					<span class="title-line">{t("hero.title.line1")}</span>
					<span class="title-line title-accent">{t("hero.title.line2")}</span>
				</h1>
				<p class="hero-description">{t("hero.subtitle")}</p>
				<div class="hero-actions">
					<a href={getLocalizedPath("/download", lang)} class="btn-primary" data-ym-goal="hero_download_click">
						<span class="btn-icon">↓</span>
						<span>{t("hero.cta.download")}</span>
					</a>
					<a href="#demo" class="btn-secondary" data-ym-goal="hero_demo_click">
						<span class="btn-icon">▶</span>
						<span>{t("hero.cta.watchDemo")}</span>
					</a>
				</div>
			</div>
			<div class="hero-visual">
				<div class="terminal">
					<div class="terminal-header">
						<span class="terminal-title">~ voxfusion</span>
						<div class="terminal-controls">
							<span></span><span></span><span></span>
						</div>
					</div>
					<div class="terminal-body">
						<div class="terminal-line">
							<span class="prompt">$</span>
							<span class="command">vox --listen</span>
						</div>
						<div class="terminal-line output">
							<span class="status">[READY]</span> Listening on Cmd+;
						</div>
						<div class="terminal-line output">
							<span class="status recording">[REC]</span> "Hey team, let's schedule..."
						</div>
						<div class="terminal-line output">
							<span class="status success">[DONE]</span> Text inserted → Messages.app
						</div>
						<div class="terminal-line">
							<span class="prompt">$</span>
							<span class="cursor">_</span>
						</div>
					</div>
				</div>
				<div class="waveform-raw">
					{[...Array(40)].map((_, i) => (
						<div class="wave-bar" style={`--i: ${i}; --h: ${20 + Math.random() * 60}%`}></div>
					))}
				</div>
			</div>
		</div>
		<div class="hero-stats">
			<div class="stat">
				<span class="stat-value">25K</span>
				<span class="stat-label">words/month FREE</span>
			</div>
			<div class="stat-divider">/</div>
			<div class="stat">
				<span class="stat-value">2</span>
				<span class="stat-label">languages</span>
			</div>
			<div class="stat-divider">/</div>
			<div class="stat">
				<span class="stat-value">∞</span>
				<span class="stat-label">applications</span>
			</div>
		</div>
	</header>

	<section id="features" class="features" data-ym-view="view_features">
		<div class="section-header">
			<span class="section-number">01</span>
			<h2 class="section-title">{t("features.tag")}</h2>
			<div class="section-line"></div>
		</div>
		<div class="section-intro">
			<h3>{t("features.title")}</h3>
			<p>{t("features.description")}</p>
		</div>
		<div class="features-grid">
			<div class="feature-card">
				<div class="feature-index">01</div>
				<div class="feature-content">
					<h4>{t("features.globalHotkey.title")}</h4>
					<p>{t("features.globalHotkey.description")}</p>
				</div>
				<div class="feature-icon">⌘;</div>
			</div>
			<div class="feature-card">
				<div class="feature-index">02</div>
				<div class="feature-content">
					<h4>{t("features.instantTranscription.title")}</h4>
					<p>{t("features.instantTranscription.description")}</p>
				</div>
				<div class="feature-icon">⚡</div>
			</div>
			<div class="feature-card">
				<div class="feature-index">03</div>
				<div class="feature-content">
					<h4>{t("features.customDictionary.title")}</h4>
					<p>{t("features.customDictionary.description")}</p>
				</div>
				<div class="feature-icon">📖</div>
			</div>
			<div class="feature-card">
				<div class="feature-index">04</div>
				<div class="feature-content">
					<h4>{t("features.history.title")}</h4>
					<p>{t("features.history.description")}</p>
				</div>
				<div class="feature-icon">⏱</div>
			</div>
			<div class="feature-card">
				<div class="feature-index">05</div>
				<div class="feature-content">
					<h4>{t("features.languages.title")}</h4>
					<p>{t("features.languages.description")}</p>
				</div>
				<div class="feature-icon">🌐</div>
			</div>
			<div class="feature-card">
				<div class="feature-index">06</div>
				<div class="feature-content">
					<h4>{t("features.simpleSetup.title")}</h4>
					<p>{t("features.simpleSetup.description")}</p>
				</div>
				<div class="feature-icon">▶</div>
			</div>
		</div>

		<div class="highlight-block">
			<div class="highlight-label">{t("features.highlight.tag")}</div>
			<h3 class="highlight-title">{t("features.highlight.title")}</h3>
			<p class="highlight-desc">{t("features.highlight.description")}</p>
			<ul class="highlight-list">
				<li><span class="check">[✓]</span> {t("features.highlight.list1")}</li>
				<li><span class="check">[✓]</span> {t("features.highlight.list2")}</li>
				<li><span class="check">[✓]</span> {t("features.highlight.list3")}</li>
			</ul>
		</div>
	</section>

	<section id="demo" class="demo" data-ym-view="view_demo">
		<div class="section-header">
			<span class="section-number">02</span>
			<h2 class="section-title">{t("demo.tag")}</h2>
			<div class="section-line"></div>
		</div>
		<div class="section-intro">
			<h3>{t("demo.title")}</h3>
			<p>{t("demo.description")}</p>
		</div>
		<div class="demo-content">
			<div class="demo-video">
				<div class="video-frame">
					<div class="video-scanlines"></div>
					<div class="video-placeholder">
						<button class="play-btn" data-ym-goal="demo_play_click">▶</button>
						<span class="video-duration">2:34</span>
					</div>
				</div>
			</div>
			<div class="demo-steps">
				<div class="step">
					<div class="step-number">01</div>
					<div class="step-content">
						<h4>{t("demo.step1.title")}</h4>
						<p>{t("demo.step1.description")}</p>
					</div>
				</div>
				<div class="step">
					<div class="step-number">02</div>
					<div class="step-content">
						<h4>{t("demo.step2.title")}</h4>
						<p>{t("demo.step2.description")}</p>
					</div>
				</div>
				<div class="step">
					<div class="step-number">03</div>
					<div class="step-content">
						<h4>{t("demo.step3.title")}</h4>
						<p>{t("demo.step3.description")}</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="pricing" class="pricing" data-ym-view="view_pricing">
		<div class="section-header">
			<span class="section-number">03</span>
			<h2 class="section-title">{t("pricing.tag")}</h2>
			<div class="section-line"></div>
		</div>
		<div class="section-intro">
			<h3>{t("pricing.title")}</h3>
			<p>{t("pricing.description")}</p>
		</div>
		<div class="pricing-grid">
			<div class="pricing-card">
				<div class="plan-header">
					<span class="plan-name">{t("pricing.free.name")}</span>
					<div class="plan-price">
						<span class="price">{t("pricing.free.price")}</span>
						<span class="period">/{t("pricing.free.period")}</span>
					</div>
				</div>
				<p class="plan-desc">{t("pricing.free.description")}</p>
				<ul class="plan-features">
					<li><span class="bullet">→</span> {t("pricing.free.feature1")}</li>
					<li><span class="bullet">→</span> {t("pricing.free.feature2")}</li>
					<li><span class="bullet">→</span> {t("pricing.free.feature3")}</li>
					<li><span class="bullet">→</span> {t("pricing.free.feature4")}</li>
					<li><span class="bullet">→</span> {t("pricing.free.feature5")}</li>
				</ul>
				<a href={getLocalizedPath("/download", lang)} class="plan-cta" data-ym-goal="pricing_free_click">{t("pricing.free.cta")}</a>
			</div>
			<div class="pricing-card featured">
				<div class="featured-badge">{t("pricing.pro.badge")}</div>
				<div class="plan-header">
					<span class="plan-name">{t("pricing.pro.name")}</span>
					<div class="plan-price">
						<span class="price">{t("pricing.pro.price")}</span>
						<span class="period">/{t("pricing.pro.period")}</span>
					</div>
				</div>
				<p class="plan-desc">{t("pricing.pro.description")}</p>
				<ul class="plan-features">
					<li><span class="bullet">→</span> <strong>{t("pricing.pro.feature1")}</strong>{t("pricing.pro.feature1.suffix")}</li>
					<li><span class="bullet">→</span> {t("pricing.pro.feature2")}</li>
					<li><span class="bullet">→</span> {t("pricing.pro.feature3")}</li>
					<li><span class="bullet">→</span> {t("pricing.pro.feature4")}</li>
				</ul>
				<a href={getLocalizedPath("/download", lang)} class="plan-cta primary" data-ym-goal="pricing_pro_click">{t("pricing.pro.cta")}</a>
			</div>
		</div>
		<p class="pricing-note">{t("pricing.faq")} <a href="mailto:hello@voxfusion.com">hello@voxfusion.com</a> {t("pricing.faq.suffix")}</p>
	</section>

	<section class="cta">
		<div class="cta-inner">
			<h2>{t("cta.title")}</h2>
			<p>{t("cta.description")}</p>
			<a href={getLocalizedPath("/download", lang)} class="cta-btn" data-ym-goal="bottom_cta_click">
				<span>↓</span> {t("cta.button")}
			</a>
		</div>
	</section>

	<footer class="footer">
		<div class="footer-grid">
			<div class="footer-brand">
				<span class="footer-logo">[VOX<span>FUSION</span>]</span>
				<p>{t("footer.tagline")}</p>
				<div class="social-links">
					<a href="#">X</a>
					<a href="#">GH</a>
					<a href="#">DC</a>
				</div>
			</div>
			<div class="footer-links">
				<div class="link-group">
					<h4>{t("footer.product")}</h4>
					<a href="#features">{t("nav.features")}</a>
					<a href="#pricing">{t("nav.pricing")}</a>
					<a href="#demo">{t("nav.demo")}</a>
					<a href="#">{t("footer.changelog")}</a>
				</div>
				<div class="link-group">
					<h4>{t("footer.company")}</h4>
					<a href="#">{t("footer.about")}</a>
					<a href="#">{t("footer.blog")}</a>
					<a href="#">{t("footer.careers")}</a>
					<a href="mailto:hello@voxfusion.com">{t("footer.contact")}</a>
				</div>
				<div class="link-group">
					<h4>{t("footer.legal")}</h4>
					<a href="#">{t("footer.privacy")}</a>
					<a href="#">{t("footer.terms")}</a>
					<a href="#">{t("footer.security")}</a>
				</div>
			</div>
		</div>
		<div class="footer-bottom">
			<span>&copy; 2025 {t("footer.copyright")}</span>
			<span class="status"><span class="status-dot"></span> {t("footer.status")}</span>
		</div>
	</footer>
	<YandexMetrika />
</body>
</html>

<style>
	@keyframes blink {
		0%, 50% { opacity: 1; }
		51%, 100% { opacity: 0; }
	}

	@keyframes wave {
		0%, 100% { transform: scaleY(var(--h)); }
		50% { transform: scaleY(calc(var(--h) * 0.3)); }
	}

	@keyframes scan {
		0% { transform: translateY(-100%); }
		100% { transform: translateY(100%); }
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	a {
		text-decoration: none;
		color: inherit;
	}

	html {
		font-family: "JetBrains Mono", "Space Mono", monospace;
		background: #0a0a0a;
		color: #e0e0e0;
		scroll-behavior: smooth;
		font-size: 15px;
	}

	body {
		min-height: 100vh;
		position: relative;
	}

	.grid-overlay {
		position: fixed;
		inset: 0;
		background-image:
			linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
		background-size: 40px 40px;
		pointer-events: none;
		z-index: 0;
	}

	/* Navigation */
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		border-bottom: 1px solid #222;
		background: rgba(10, 10, 10, 0.95);
		backdrop-filter: blur(10px);
	}

	.nav-inner {
		max-width: 1400px;
		margin: 0 auto;
		padding: 16px 32px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		font-size: 18px;
		font-weight: 700;
		letter-spacing: 0.1em;
		color: #fff;
	}

	.logo-bracket {
		color: #fff;
	}

	.logo-accent {
		color: #666;
	}

	.nav-links {
		display: flex;
		gap: 32px;
	}

	.nav-link {
		font-size: 13px;
		color: #888;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: color 0.2s;
	}

	.nav-link:hover {
		color: #fff;
	}

	.link-index {
		color: #ff3e00;
		margin-right: 8px;
	}

	.nav-cta {
		padding: 10px 20px;
		border: 1px solid #ff3e00;
		color: #ff3e00;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: all 0.2s;
	}

	.nav-cta:hover {
		background: #ff3e00;
		color: #000;
	}

	/* Hero */
	.hero {
		min-height: 100vh;
		padding: 120px 32px 60px;
		max-width: 1400px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 80px;
		align-items: center;
	}

	.hero-label {
		display: flex;
		align-items: center;
		gap: 16px;
		margin-bottom: 24px;
	}

	.label-line {
		width: 40px;
		height: 1px;
		background: #ff3e00;
	}

	.label-text {
		font-size: 12px;
		color: #ff3e00;
		text-transform: uppercase;
		letter-spacing: 0.2em;
	}

	.hero-title {
		font-size: clamp(36px, 5vw, 64px);
		font-weight: 700;
		line-height: 1.1;
		margin-bottom: 24px;
	}

	.title-line {
		display: block;
	}

	.title-accent {
		color: #ff3e00;
	}

	.hero-description {
		font-size: 14px;
		line-height: 1.8;
		color: #888;
		max-width: 500px;
		margin-bottom: 40px;
	}

	.hero-actions {
		display: flex;
		gap: 16px;
	}

	.btn-primary, .btn-secondary {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		padding: 14px 28px;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 600;
		transition: all 0.2s;
	}

	.btn-primary {
		background: #ff3e00;
		color: #000;
		border: 1px solid #ff3e00;
	}

	.btn-primary:hover {
		background: #fff;
		border-color: #fff;
	}

	.btn-secondary {
		background: transparent;
		color: #888;
		border: 1px solid #333;
	}

	.btn-secondary:hover {
		color: #fff;
		border-color: #666;
	}

	.btn-icon {
		font-size: 16px;
	}

	/* Terminal */
	.hero-visual {
		position: relative;
	}

	.terminal {
		background: #111;
		border: 1px solid #333;
		border-radius: 4px;
		overflow: hidden;
	}

	.terminal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 12px 16px;
		background: #1a1a1a;
		border-bottom: 1px solid #333;
	}

	.terminal-title {
		font-size: 12px;
		color: #666;
	}

	.terminal-controls {
		display: flex;
		gap: 8px;
	}

	.terminal-controls span {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: #333;
	}

	.terminal-body {
		padding: 20px;
		font-size: 13px;
		line-height: 2;
	}

	.terminal-line {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.prompt {
		color: #ff3e00;
	}

	.command {
		color: #fff;
	}

	.output {
		color: #666;
	}

	.status {
		color: #666;
	}

	.status.recording {
		color: #ff3e00;
	}

	.status.success {
		color: #00ff88;
	}

	.cursor {
		animation: blink 1s infinite;
		color: #ff3e00;
	}

	.waveform-raw {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		gap: 4px;
		height: 80px;
		margin-top: 32px;
		padding: 0 20px;
	}

	.wave-bar {
		width: 4px;
		background: linear-gradient(to top, #ff3e00, #ff6b4a);
		border-radius: 2px;
		transform-origin: bottom;
		animation: wave 1s ease-in-out infinite;
		animation-delay: calc(var(--i) * 0.05s);
		height: var(--h);
	}

	/* Stats */
	.hero-stats {
		display: flex;
		align-items: center;
		gap: 40px;
		margin-top: 80px;
		padding-top: 40px;
		border-top: 1px solid #222;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.stat-value {
		font-size: 32px;
		font-weight: 700;
		color: #ff3e00;
	}

	.stat-label {
		font-size: 11px;
		color: #666;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.stat-divider {
		font-size: 24px;
		color: #333;
	}

	/* Sections */
	.features, .demo, .pricing {
		padding: 120px 32px;
		max-width: 1400px;
		margin: 0 auto;
	}

	.section-header {
		display: flex;
		align-items: center;
		gap: 20px;
		margin-bottom: 48px;
	}

	.section-number {
		font-size: 12px;
		color: #ff3e00;
		font-weight: 700;
	}

	.section-title {
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: #666;
	}

	.section-line {
		flex: 1;
		height: 1px;
		background: #222;
	}

	.section-intro {
		max-width: 700px;
		margin-bottom: 64px;
	}

	.section-intro h3 {
		font-size: clamp(28px, 4vw, 40px);
		font-weight: 700;
		margin-bottom: 16px;
	}

	.section-intro p {
		font-size: 14px;
		color: #888;
