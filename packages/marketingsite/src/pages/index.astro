---
/**
 * VERSION 1: BRUTALIST / RAW INDUSTRIAL
 *
 * Design Direction: Raw, industrial, unapologetic. Exposed grid structures,
 * monospace typography, harsh contrasts, visible construction elements.
 * Think concrete architecture meets command-line interfaces.
 */
import { useTranslations, defaultLang, getLocalizedPath } from "../i18n/utils";
import Footer from "../components/Footer.astro";
import Umami from "../components/Umami.astro";
import Seo from "../components/Seo.astro";
import { softwareApplicationSchema } from "../seo";

const lang = defaultLang;
const t = useTranslations(lang);
const title = t("meta.title");
const description = t("meta.description");
const schema = softwareApplicationSchema(description);
---

<!doctype html>
<html lang={lang}>
<head>
	<meta charset="UTF-8" />
	<Seo title={title} description={description} lang={lang} schema={schema} />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
	<title>{title}</title>
</head>
<body>
	<div class="grid-overlay"></div>

	<nav class="nav">
		<div class="nav-inner">
			<a href="/" class="logo">
				<span class="logo-bracket">[</span>VOX<span class="logo-accent">FUSION</span><span class="logo-bracket">]</span>
			</a>
			<a href={getLocalizedPath("/download", lang)} class="nav-cta">{t("nav.download")} →</a>
		</div>
	</nav>

	<header class="hero">
		<div class="hero-grid">
			<div class="hero-content">
				<div class="hero-label">
					<span class="label-line"></span>
					<span class="label-text">VOICE_TO_TEXT.EXE</span>
				</div>
				<h1 class="hero-title">
					<span class="title-line">{t("hero.title.line1")}</span>
					<span class="title-line title-accent">{t("hero.title.line2")}</span>
				</h1>
				<p class="hero-description">{t("hero.subtitle")}</p>
				<div class="hero-actions">
					<a href={getLocalizedPath("/download", lang)} class="btn-primary" data-umami-event="hero_download_click">
						<span class="btn-icon">↓</span>
						<span>{t("hero.cta.download")}</span>
					</a>
					<a href="https://github.com/voxfusion/voxfusion" target="_blank" rel="noopener noreferrer" class="btn-secondary" data-umami-event="hero_github_click">
						<svg class="btn-icon" viewBox="0 0 1024 1024" width="16" height="16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M512 0C229.12 0 0 229.12 0 512c0 226.56 146.56 417.92 350.08 485.76 25.6 4.48 35.2-10.88 35.2-24.32 0-12.16-.64-52.48-.64-95.36-128.64 23.68-161.92-31.36-172.16-60.16-5.76-14.72-30.72-60.16-52.48-72.32-17.92-9.6-43.52-33.28-.64-33.92 40.32-.64 69.12 37.12 78.72 52.48 46.08 77.44 119.68 55.68 149.12 42.24 4.48-33.28 17.92-55.68 32.64-68.48-113.92-12.8-232.96-56.96-232.96-252.8 0-55.68 19.84-101.76 52.48-137.6-5.12-12.8-23.04-65.28 5.12-135.68 0 0 42.88-13.44 140.8 52.48 40.96-11.52 84.48-17.28 128-17.28s87.04 5.76 128 17.28c97.92-66.56 140.8-52.48 140.8-52.48 28.16 70.4 10.24 122.88 5.12 135.68 32.64 35.84 52.48 81.28 52.48 137.6 0 196.48-119.68 240-233.6 252.8 18.56 16 34.56 46.72 34.56 94.72 0 68.48-.64 123.52-.64 140.8 0 13.44 9.6 29.44 35.2 24.32C877.44 929.92 1024 737.92 1024 512 1024 229.12 794.88 0 512 0" clip-rule="evenodd"/></svg>
						<span>{t("nav.github")}</span>
					</a>
				</div>
			</div>
			<div class="hero-visual">
				<div class="terminal">
					<div class="terminal-header">
						<span class="terminal-title">~ voxfusion</span>
						<div class="terminal-controls">
							<span></span><span></span><span></span>
						</div>
					</div>
					<div class="terminal-body">
						<div class="terminal-line">
							<span class="prompt">$</span>
							<span class="command">vox --listen</span>
						</div>
						<div class="terminal-line output">
							<span class="status">[READY]</span> Listening on Cmd+;
						</div>
						<div class="terminal-line output">
							<span class="status recording">[REC]</span> "Hey team, let's schedule..."
						</div>
						<div class="terminal-line output">
							<span class="status">[LOCAL]</span> Transcribing on-device · whisper.cpp
						</div>
						<div class="terminal-line output">
							<span class="status success">[DONE]</span> Text inserted → Messages.app
						</div>
						<div class="terminal-line">
							<span class="prompt">$</span>
							<span class="cursor">_</span>
						</div>
					</div>
				</div>
				<div class="waveform-raw">
					{[...Array(40)].map((_, i) => (
						<div class="wave-bar" style={`--i: ${i}; --h: ${20 + Math.random() * 60}%`}></div>
					))}
				</div>
			</div>
		</div>
		<div class="hero-stats">
			<div class="stat">
				<span class="stat-value">{t("hero.stat.words.value")}</span>
				<span class="stat-label">{t("hero.stat.words.label")}</span>
			</div>
			<div class="stat-divider">/</div>
			<div class="stat">
				<span class="stat-value">{t("hero.stat.languages.value")}</span>
				<span class="stat-label">{t("hero.stat.languages.label")}</span>
			</div>
			<div class="stat-divider">/</div>
			<div class="stat">
				<span class="stat-value">{t("hero.stat.apps.value")}</span>
				<span class="stat-label">{t("hero.stat.apps.label")}</span>
			</div>
		</div>
	</header>

	<section id="features" class="features" data-umami-view="view_features">
		<div class="section-header">
			<span class="section-number">01</span>
			<h2 class="section-title">{t("features.tag")}</h2>
			<div class="section-line"></div>
		</div>
		<div class="section-intro">
			<h3>{t("features.title")}</h3>
			<p>{t("features.description")}</p>
		</div>
		<div class="features-grid">
			<div class="feature-card">
				<div class="feature-index">01</div>
				<div class="feature-content">
					<h4>{t("features.globalHotkey.title")}</h4>
					<p>{t("features.globalHotkey.description")}</p>
				</div>
				<div class="feature-icon">⌘;</div>
			</div>
			<div class="feature-card">
				<div class="feature-index">02</div>
				<div class="feature-content">
					<h4>{t("features.instantTranscription.title")}</h4>
					<p>{t("features.instantTranscription.description")}</p>
				</div>
				<div class="feature-icon">⚡</div>
			</div>
			<div class="feature-card">
				<div class="feature-index">03</div>
				<div class="feature-content">
					<h4>{t("features.customDictionary.title")}</h4>
					<p>{t("features.customDictionary.description")}</p>
				</div>
				<div class="feature-icon">📖</div>
			</div>
			<div class="feature-card">
				<div class="feature-index">04</div>
				<div class="feature-content">
					<h4>{t("features.history.title")}</h4>
					<p>{t("features.history.description")}</p>
				</div>
				<div class="feature-icon">⏱</div>
			</div>
		</div>

		<div class="highlight-block">
			<div class="highlight-label">{t("features.highlight.tag")}</div>
			<h3 class="highlight-title">{t("features.highlight.title")}</h3>
			<p class="highlight-desc">{t("features.highlight.description")}</p>
			<ul class="highlight-list">
				<li><span class="check">[✓]</span> {t("features.highlight.list1")}</li>
				<li><span class="check">[✓]</span> {t("features.highlight.list2")}</li>
				<li><span class="check">[✓]</span> {t("features.highlight.list3")}</li>
			</ul>
		</div>
	</section>

	<section class="cta">
		<div class="cta-inner">
			<h2>{t("cta.title")}</h2>
			<p>{t("cta.description")}</p>
			<a href={getLocalizedPath("/download", lang)} class="cta-btn" data-umami-event="bottom_cta_click">
				<span>↓</span> {t("cta.button")}
			</a>
		</div>
	</section>

	<Footer lang={lang} />
	<Umami />

</body>
</html>

<style>
	@keyframes blink {
		0%, 50% { opacity: 1; }
		51%, 100% { opacity: 0; }
	}

	@keyframes wave {
		0%, 100% { transform: scaleY(var(--h)); }
		50% { transform: scaleY(calc(var(--h) * 0.3)); }
	}

	@keyframes scan {
		0% { transform: translateY(-100%); }
		100% { transform: translateY(100%); }
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	a {
		text-decoration: none;
		color: inherit;
	}

	html {
		font-family: "JetBrains Mono", "Space Mono", monospace;
		background: #0a0a0a;
		color: #e0e0e0;
		scroll-behavior: smooth;
		font-size: 15px;
	}

	body {
		min-height: 100vh;
		position: relative;
	}

	.grid-overlay {
		position: fixed;
		inset: 0;
		background-image:
			linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
		background-size: 40px 40px;
		pointer-events: none;
		z-index: 0;
	}

	/* Navigation */
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		border-bottom: 1px solid #222;
		background: rgba(10, 10, 10, 0.95);
		backdrop-filter: blur(10px);
	}

	.nav-inner {
		max-width: 1400px;
		margin: 0 auto;
		padding: 16px 32px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		font-size: 18px;
		font-weight: 700;
		letter-spacing: 0.1em;
		color: #fff;
	}

	.logo-bracket {
		color: #fff;
	}

	.logo-accent {
		color: #666;
	}

	.nav-links {
		display: flex;
		gap: 32px;
	}

	.nav-link {
		font-size: 13px;
		color: #888;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: color 0.2s;
	}

	.nav-link:hover {
		color: #fff;
	}

	.link-index {
		color: #ff3e00;
		margin-right: 8px;
	}

	.nav-cta {
		padding: 10px 20px;
		border: 1px solid #ff3e00;
		color: #ff3e00;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: all 0.2s;
	}

	.nav-cta:hover {
		background: #ff3e00;
		color: #000;
	}

	/* Hero */
	.hero {
		min-height: 100vh;
		padding: 120px 32px 60px;
		max-width: 1400px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 80px;
		align-items: center;
	}

	.hero-label {
		display: flex;
		align-items: center;
		gap: 16px;
		margin-bottom: 24px;
	}

	.label-line {
		width: 40px;
		height: 1px;
		background: #ff3e00;
	}

	.label-text {
		font-size: 12px;
		color: #ff3e00;
		text-transform: uppercase;
		letter-spacing: 0.2em;
	}

	.hero-title {
		font-size: clamp(36px, 5vw, 64px);
		font-weight: 700;
		line-height: 1.1;
		margin-bottom: 24px;
	}

	.title-line {
		display: block;
	}

	.title-accent {
		color: #ff3e00;
	}

	.hero-description {
		font-size: 14px;
		line-height: 1.8;
		color: #888;
		max-width: 500px;
		margin-bottom: 40px;
	}

	.hero-actions {
		display: flex;
		gap: 16px;
	}

	.btn-primary, .btn-secondary {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		padding: 14px 28px;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 600;
		transition: all 0.2s;
	}

	.btn-primary {
		background: #ff3e00;
		color: #000;
		border: 1px solid #ff3e00;
	}

	.btn-primary:hover {
		background: #fff;
		border-color: #fff;
	}

	.btn-secondary {
		background: transparent;
		color: #888;
		border: 1px solid #333;
	}

	.btn-secondary:hover {
		color: #fff;
		border-color: #666;
	}

	.btn-icon {
		font-size: 16px;
	}

	/* Terminal */
	.hero-visual {
		position: relative;
	}

	.terminal {
		background: #111;
		border: 1px solid #333;
		border-radius: 4px;
		overflow: hidden;
	}

	.terminal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 12px 16px;
		background: #1a1a1a;
		border-bottom: 1px solid #333;
	}

	.terminal-title {
		font-size: 12px;
		color: #666;
	}

	.terminal-controls {
		display: flex;
		gap: 8px;
	}

	.terminal-controls span {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: #333;
	}

	.terminal-body {
		padding: 20px;
		font-size: 13px;
		line-height: 2;
	}

	.terminal-line {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.prompt {
		color: #ff3e00;
	}

	.command {
		color: #fff;
	}

	.output {
		color: #666;
	}

	.status {
		color: #666;
	}

	.status.recording {
		color: #ff3e00;
	}

	.status.success {
		color: #00ff88;
	}

	.cursor {
		animation: blink 1s infinite;
		color: #ff3e00;
	}

	.waveform-raw {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		gap: 4px;
		height: 80px;
		margin-top: 32px;
		padding: 0 20px;
	}

	.wave-bar {
		width: 4px;
		background: linear-gradient(to top, #ff3e00, #ff6b4a);
		border-radius: 2px;
		transform-origin: bottom;
		animation: wave 1s ease-in-out infinite;
		animation-delay: calc(var(--i) * 0.05s);
		height: var(--h);
	}

	/* Stats */
	.hero-stats {
		display: flex;
		align-items: center;
		gap: 40px;
		margin-top: 80px;
		padding-top: 40px;
		border-top: 1px solid #222;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.stat-value {
		font-size: 32px;
		font-weight: 700;
		color: #ff3e00;
	}

	.stat-label {
		font-size: 11px;
		color: #666;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.stat-divider {
		font-size: 24px;
		color: #333;
	}

	/* Sections */
	.features {
		padding: 120px 32px;
		max-width: 1400px;
		margin: 0 auto;
	}

	.section-header {
		display: flex;
		align-items: center;
		gap: 20px;
		margin-bottom: 48px;
	}

	.section-number {
		font-size: 12px;
		color: #ff3e00;
		font-weight: 700;
	}

	.section-title {
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: #666;
	}

	.section-line {
		flex: 1;
		height: 1px;
		background: #222;
	}

	.section-intro {
		max-width: 700px;
		margin-bottom: 64px;
	}

	.section-intro h3 {
		font-size: clamp(28px, 4vw, 40px);
		font-weight: 700;
		margin-bottom: 16px;
	}

	.section-intro p {
		font-size: 14px;
		color: #888;
		line-height: 1.8;
	}

	/* Features Grid */
	.features-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1px;
		background: #222;
		border: 1px solid #222;
		margin-bottom: 80px;
	}

	.feature-card {
		background: #0a0a0a;
		padding: 32px;
		display: flex;
		flex-direction: column;
		gap: 20px;
		transition: background 0.3s;
	}

	.feature-card:hover {
		background: #111;
	}

	.feature-index {
		font-size: 11px;
		color: #ff3e00;
		font-weight: 700;
	}

	.feature-content h4 {
		font-size: 16px;
		font-weight: 600;
		margin-bottom: 8px;
	}

	.feature-content p {
		font-size: 13px;
		color: #666;
		line-height: 1.7;
	}

	.feature-icon {
		font-size: 24px;
		margin-top: auto;
	}

	/* Highlight Block */
	.highlight-block {
		border: 1px solid #ff3e00;
		padding: 48px;
		background: linear-gradient(135deg, rgba(255, 62, 0, 0.05) 0%, transparent 100%);
	}

	.highlight-label {
		font-size: 11px;
		color: #ff3e00;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		margin-bottom: 24px;
	}

	.highlight-title {
		font-size: clamp(24px, 3vw, 32px);
		font-weight: 700;
		margin-bottom: 16px;
	}

	.highlight-desc {
		font-size: 14px;
		color: #888;
		line-height: 1.8;
		margin-bottom: 32px;
		max-width: 600px;
	}

	.highlight-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.highlight-list li {
		font-size: 14px;
		color: #888;
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.check {
		color: #ff3e00;
		font-family: monospace;
	}


	/* CTA */
	.cta {
		padding: 120px 32px;
		background: #0d0d0d;
		text-align: center;
	}

	.cta-inner {
		max-width: 600px;
		margin: 0 auto;
	}

	.cta h2 {
		font-size: clamp(32px, 4vw, 48px);
		font-weight: 700;
		margin-bottom: 16px;
	}

	.cta p {
		font-size: 14px;
		color: #888;
		margin-bottom: 40px;
	}

	.cta-btn {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		padding: 18px 40px;
		background: #ff3e00;
		color: #000;
		font-size: 14px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 700;
		transition: all 0.2s;
	}

	.cta-btn:hover {
		background: #fff;
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.hero-grid {
			grid-template-columns: 1fr;
			gap: 60px;
		}

		.features-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.nav-links {
			display: none;
		}

		.features-grid {
			grid-template-columns: 1fr;
		}

		.hero-stats {
			flex-wrap: wrap;
			gap: 24px;
		}

		.stat-divider {
			display: none;
		}
	}
</style>
