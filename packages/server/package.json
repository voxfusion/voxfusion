{
	"name": "@voxfusion/server",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "NODE_ENV=development bun run --bun --hot src/index.ts",
		"build": "bun build --bun src/index.ts --outdir dist --target bun",
		"start": "bun run --bun dist/index.js",
		"lint": "biome lint ./src",
		"lint:fix": "biome lint --write ./src",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"postinstall": "patch-package"
	},
	"dependencies": {
		"@elysiajs/bearer": "^1.1.0",
		"@elysiajs/cors": "^1.1.1",
		"@elysiajs/html": "^1.4.0",
		"@gladiaio/sdk": "^0.6.1",
		"better-auth": "1.4.15",
		"drizzle-orm": "^0.38.3",
		"elysia": "^1.2.10",
		"groq-sdk": "^0.37.0",
		"pino": "^10.3.1",
		"postgres": "^3.4.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/bun": "latest",
		"drizzle-kit": "^0.30.1",
		"patch-package": "^8.0.1",
		"postinstall-postinstall": "^2.1.0",
		"typescript": "^5.7.2"
	}
}
