{
	"name": "@voxfusion/server",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "bun run --bun --hot src/index.ts",
		"build": "bun build --bun src/index.ts --outdir dist --target bun",
		"start": "bun run --bun dist/index.js",
		"lint": "biome lint ./src",
		"lint:fix": "biome lint --write ./src",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"elysia": "^1.2.10",
		"@elysiajs/cors": "^1.1.1",
		"@elysiajs/bearer": "^1.1.0",
		"drizzle-orm": "^0.38.3",
		"postgres": "^3.4.5",
		"better-auth": "^1.1.14"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/bun": "latest",
		"drizzle-kit": "^0.30.1",
		"typescript": "^5.7.2"
	}
}
