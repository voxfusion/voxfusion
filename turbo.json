{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "build/**", ".output/**", "src-tauri/target/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"lint:fix": {
			"dependsOn": ["^lint:fix"]
		},
		"format": {
			"cache": false
		},
		"check": {
			"dependsOn": ["^check"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		}
	}
}
